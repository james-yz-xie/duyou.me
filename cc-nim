#!/bin/bash
# ccn: One command to launch Claude Code with NVIDIA NIM (Agent Gateway Edition)
# Usage: ccn [model] [prompt] | ccn list

set -euo pipefail

# Determine script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PROXY_PORT=8742
PROXY_SCRIPT="$SCRIPT_DIR/nim-proxy.py"
PROXY_CONFIG="$SCRIPT_DIR/litellm-config.yaml"
PROXY_REQUIREMENTS="$SCRIPT_DIR/requirements-nim-gateway.txt"
PROXY_VENV="$SCRIPT_DIR/.venv-nim-gateway"
CCN_LOG="/tmp/ccn-session.log"
CCN_DETAILED_LOG="/tmp/ccn-detailed-$(date +%Y%m%d-%H%M%S).log"
export UV_CACHE_DIR="${TMPDIR:-/tmp}/duyou-uv-cache"
DEFAULT_MODEL="agent-best"

# Logging function
log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $*"
    echo "$msg" | tee -a "$CCN_LOG" | tee -a "$CCN_DETAILED_LOG"
}

log_error() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: $*"
    echo "$msg" >&2
    echo "$msg" >> "$CCN_LOG"
    echo "$msg" >> "$CCN_DETAILED_LOG"
}

pick_python() {
    local candidate
    for candidate in python3.12 python3.11 python3; do
        if command -v "$candidate" >/dev/null 2>&1; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

bootstrap_gateway_env() {
    local pybin="$1"

    if [ ! -x "$PROXY_VENV/bin/python" ]; then
        echo "Creating gateway virtualenv at $PROXY_VENV ..."
        if command -v uv >/dev/null 2>&1; then
            uv venv "$PROXY_VENV" --python "$pybin"
        else
            "$pybin" -m venv "$PROXY_VENV"
        fi
    fi

    if ! "$PROXY_VENV/bin/python" -c "import fastapi, uvicorn, litellm" >/dev/null 2>&1; then
        echo "Installing gateway dependencies ..."
        if command -v uv >/dev/null 2>&1; then
            uv pip install --python "$PROXY_VENV/bin/python" -r "$PROXY_REQUIREMENTS"
        else
            "$PROXY_VENV/bin/python" -m pip install -r "$PROXY_REQUIREMENTS"
        fi
    fi
}

PYTHON_BIN="$(pick_python || true)"
if [ -z "${PYTHON_BIN:-}" ]; then
    log_error "No supported Python found. Install python3.12 or python3.11."
    exit 1
fi
log "Python: $PYTHON_BIN"

# List models command
if [ "${1:-}" = "list" ]; then
    if [ -z "${NVIDIA_NIM_API_KEY:-}" ]; then
        echo "✗ NVIDIA_NIM_API_KEY not set. Run: source ~/.zshrc"
        exit 1
    fi
    echo "Fetching available NVIDIA NIM models ..."
    curl -s https://integrate.api.nvidia.com/v1/models \
      -H "Authorization: Bearer $NVIDIA_NIM_API_KEY" \
      | python3 -c "
import json, sys

DEFAULT = '$DEFAULT_MODEL'

TIER1 = ['nvidia/llama-3.1-nemotron-ultra-253b-v1', 'qwen/qwen3-coder-480b-a35b-instruct', 'z-ai/glm5', 'z-ai/glm-5.1', 'z-ai/glm4.7']
TIER2 = ['nvidia/llama-3.3-nemotron-super-49b-v1.5', 'mistralai/mistral-large-3-675b-instruct-2512', 'mistralai/devstral-2-123b-instruct-2512', 'moonshotai/kimi-k2.5', 'moonshotai/kimi-k2-thinking', 'qwen/qwen3.5-397b-a17b', 'minimaxai/minimax-m2.7', 'minimaxai/minimax-m2.5', 'deepseek-ai/deepseek-v3.2', 'meta/llama-4-maverick-17b-128e-instruct', 'openai/gpt-oss-120b']
TIER3 = ['meta/llama-3.1-405b-instruct', 'meta/llama-3.3-70b-instruct', 'mistralai/mistral-small-4-119b-2603', 'qwen/qwen3-next-80b-a3b-thinking', 'google/gemma-4-31b-it']

data = json.load(sys.stdin)
available = set(m['id'] for m in data.get('data', []))

def show_tier(name, models):
    shown = [m for m in models if m in available]
    if not shown: return
    print(f'\n  {name}\n  {\"─\" * 60}')
    for m in shown:
        tag = ' ← default' if m == DEFAULT else ''
        print(f'    ccn {m}{tag}')

show_tier('Tier 1 · Best Tool Calling', TIER1)
show_tier('Tier 2 · Good Tool Calling', TIER2)
show_tier('Tier 3 · General Purpose', TIER3)
"
    exit 0
fi

# Smart argument parsing: ccn [model] [prompt]
MODEL="$DEFAULT_MODEL"
PROMPT=""
if [ $# -gt 0 ]; then
    # If first arg contains / or is a known model alias, treat it as model name
    if [[ "$1" == *"/"* ]] || [[ "$1" == "agent-best" ]] || [[ "$1" == "agent-fallback" ]]; then
        MODEL="$1"
        shift
        PROMPT="$*"
    else
        # First arg is not a model, so all args are the prompt
        PROMPT="$*"
    fi
fi

log "Model: $MODEL"
log "Prompt: ${PROMPT:-<interactive>}"

bootstrap_gateway_env "$PYTHON_BIN"
log "Gateway environment ready"

# Force restart proxy if config changed or not running
if lsof -i :$PROXY_PORT -sTCP:LISTEN &>/dev/null; then
    PROXY_PID=$(lsof -ti :$PROXY_PORT -sTCP:LISTEN)
    # Check if it's the right script
    if ! ps -p "$PROXY_PID" -o args= | grep -q "$PROXY_SCRIPT"; then
        log "Restarting NIM Agent Gateway (killing incompatible PID: $PROXY_PID) ..."
        kill -9 "$PROXY_PID" &>/dev/null
        sleep 0.5
    fi
else
    log "Starting NIM Agent Gateway on port $PROXY_PORT for model: $MODEL ..."
fi

export LITELLM_CONFIG="$PROXY_CONFIG"
export NIM_DEFAULT_MODEL="$MODEL"
export PROXY_PORT="$PROXY_PORT"

# Ensure proxy is running
if ! curl -s http://127.0.0.1:$PROXY_PORT/ping &>/dev/null; then
    log "Starting proxy process..."
    "$PROXY_VENV/bin/python" "$PROXY_SCRIPT" &>/tmp/nim-proxy.log &
    PROXY_START=$(date +%s)
    # Wait for proxy to be ready
    PROXY_READY=false
    for i in $(seq 1 30); do
        if curl -s http://127.0.0.1:$PROXY_PORT/ping &>/dev/null; then
            PROXY_READY=true
            PROXY_ELAPSED=$(( $(date +%s) - PROXY_START ))
            log "Proxy ready in ${PROXY_ELAPSED}s"
            break
        fi
        sleep 0.5
    done
    if [ "$PROXY_READY" = false ]; then
        log_error "Failed to start proxy. Check /tmp/nim-proxy.log"
        tail -20 /tmp/nim-proxy.log >> "$CCN_DETAILED_LOG" 2>/dev/null
        exit 1
    fi
else
    log "Proxy already running on port $PROXY_PORT"
fi

log "Agent Gateway ready (Model: $MODEL)"

# Log session info header
log "========================================="
log "CCN Session Started"
log "  Model:  $MODEL"
log "  Prompt: ${PROMPT:-<interactive>}"
log "  PID:    $$"
log "  TTY:    $([ -t 0 ] && echo 'yes' || echo 'no (non-interactive)')"
log "========================================="

if [ -n "$PROMPT" ]; then
    log "Launching Claude Code with prompt..."
else
    log "Launching Claude Code interactive mode..."
fi
echo ""

# Set up cleanup handler
cleanup() {
    EXIT_CODE=$?
    log "========================================="
    log "Claude Code session ended (exit code: $EXIT_CODE)"
    log "Session log:   $CCN_LOG"
    log "Detailed log:  $CCN_DETAILED_LOG"
    log "Proxy log:     /tmp/nim-proxy.log"
    log "========================================="
    
    # Record git status if any changes were made
    GIT_STATUS=$(git status --short 2>/dev/null | grep -v "^??" | head -20)
    if [ -n "$GIT_STATUS" ]; then
        log "Git changes detected:"
        echo "$GIT_STATUS" >> "$CCN_DETAILED_LOG"
    fi
}
trap cleanup EXIT

# Launch Claude Code with prompt if provided
log "Executing: claude ${PROMPT:+'[prompt provided]'}"
if [ -n "${PROMPT:-}" ]; then
    ANTHROPIC_BASE_URL="http://127.0.0.1:$PROXY_PORT" \
    ANTHROPIC_API_KEY="not-used" \
    ANTHROPIC_MODEL="$MODEL" \
    ANTHROPIC_CUSTOM_MODEL_OPTION="$MODEL" \
    ANTHROPIC_DEFAULT_HAIKU_MODEL="$MODEL" \
    ANTHROPIC_DEFAULT_SONNET_MODEL="$MODEL" \
    ANTHROPIC_DEFAULT_OPUS_MODEL="$MODEL" \
    CLAUDE_CODE_SUBAGENT_MODEL="$MODEL" \
    claude "$PROMPT"
else
    ANTHROPIC_BASE_URL="http://127.0.0.1:$PROXY_PORT" \
    ANTHROPIC_API_KEY="not-used" \
    ANTHROPIC_MODEL="$MODEL" \
    ANTHROPIC_CUSTOM_MODEL_OPTION="$MODEL" \
    ANTHROPIC_DEFAULT_HAIKU_MODEL="$MODEL" \
    ANTHROPIC_DEFAULT_SONNET_MODEL="$MODEL" \
    ANTHROPIC_DEFAULT_OPUS_MODEL="$MODEL" \
    CLAUDE_CODE_SUBAGENT_MODEL="$MODEL" \
    claude
fi
