# =============================================================================
# Duyou.me 周报自动更新 - Crontab 配置示例
# =============================================================================
# 
# 使用方法：
# 1. 编辑此文件，取消注释您需要的定时任务
# 2. 运行: crontab /path/to/crontab.example
# 3. 查看当前任务: crontab -l
# 4. 编辑任务: crontab -e
#
# Crontab 格式说明：
# ┌───────────── 分钟 (0 - 59)
# │ ┌───────────── 小时 (0 - 23)
# │ │ ┌───────────── 日期 (1 - 31)
# │ │ │ ┌───────────── 月份 (1 - 12)
# │ │ │ │ ┌───────────── 星期几 (0 - 7, 0和7都是周日)
# │ │ │ │ │
# * * * * * 命令
#
# =============================================================================

# -----------------------------------------------------------------------------
# 选项 1: 每天凌晨 2 点自动更新（推荐）
# -----------------------------------------------------------------------------
# 0 2 * * * cd /Users/james/git/duyou.me && ./scripts/auto-update-feeds.sh --both >> /tmp/duyou-feeds-update.log 2>&1

# -----------------------------------------------------------------------------
# 选项 2: 每周一上午 9 点更新（适合周报节奏）
# -----------------------------------------------------------------------------
# 0 9 * * 1 cd /Users/james/git/duyou.me && ./scripts/auto-update-feeds.sh --both >> /tmp/duyou-feeds-update.log 2>&1

# -----------------------------------------------------------------------------
# 选项 3: 每周三和周日晚上 8 点更新（高频更新）
# -----------------------------------------------------------------------------
# 0 20 * * 3,0 cd /Users/james/git/duyou.me && ./scripts/auto-update-feeds.sh --both >> /tmp/duyou-feeds-update.log 2>&1

# -----------------------------------------------------------------------------
# 选项 4: 仅更新 AI 情报 - 每天早上 8 点
# -----------------------------------------------------------------------------
# 0 8 * * * cd /Users/james/git/duyou.me && ./scripts/auto-update-feeds.sh --ai-only >> /tmp/duyou-ai-feed.log 2>&1

# -----------------------------------------------------------------------------
# 选项 5: 仅更新开源热点 - 每周一、三、五下午 6 点
# -----------------------------------------------------------------------------
# 0 18 * * 1,3,5 cd /Users/james/git/duyou.me && ./scripts/auto-update-feeds.sh --oss-only >> /tmp/duyou-oss-feed.log 2>&1

# -----------------------------------------------------------------------------
# 测试模式：每分钟运行一次（仅用于调试，记得注释掉）
# -----------------------------------------------------------------------------
# * * * * * cd /Users/james/git/duyou.me && ./scripts/auto-update-feeds.sh --dry-run >> /tmp/duyou-feeds-test.log 2>&1

# =============================================================================
# 日志管理建议
# =============================================================================
# 
# 1. 日志轮转（防止日志文件过大）：
#    在 ~/.bash_profile 或 ~/.zshrc 中添加：
#    
#    # 每周清理旧日志
#    0 0 * * 0 find /tmp -name "duyou-*.log" -mtime +7 -delete
#
# 2. 邮件通知（可选）：
#    如果希望接收执行结果邮件，在 crontab 顶部添加：
#    MAILTO=your-email@example.com
#
# 3. 错误监控：
#    可以添加错误检测脚本，当更新失败时发送通知
#
# =============================================================================
# 快速安装命令
# =============================================================================
#
# 安装 crontab（取消注释下面一行并修改路径）：
# crontab /Users/james/git/duyou.me/scripts/crontab.example
#
# 查看已安装的任务：
# crontab -l
#
# 编辑任务：
# crontab -e
#
# 删除所有任务：
# crontab -r
#
# =============================================================================
