---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import DeliveryHero from '../components/delivery/DeliveryHero.astro';
import ServiceGrid from '../components/delivery/ServiceGrid.astro';
import TechnicalEdge from '../components/delivery/TechnicalEdge.astro';
import PricingModel from '../components/delivery/PricingModel.astro';
import VideoShowcase from '../components/delivery/VideoShowcase.astro';
---

<Layout title="企业的 AI 技能递送者 | duyou.me · 行业领先的企业信息 AI 化方案">
  <main class="bg-dark">
    <!-- Hero Section -->
    <DeliveryHero />
    
    <!-- Connectivity Gap / Intro Quote -->
    <section class="py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <blockquote class="text-3xl md:text-4xl font-serif italic text-white/90 leading-snug">
          "连接，是智能化的第一步。我们让 AI 走进业务逻辑，真正触碰您的核心资产。"
        </blockquote>
      </div>
    </section>

    <!-- Video Showcase -->
    <VideoShowcase />

    <!-- Services Section -->
    <ServiceGrid />

    <!-- Technical Advantages -->
    <TechnicalEdge />

    <!-- Pricing / Business Model -->
    <PricingModel />

    <!-- Final CTA -->
    <section class="py-32 px-4 relative overflow-hidden bg-gradient-to-b from-dark to-[#0a0a0a]">
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-8">
          准备好开启您的 <br/><span class="text-gold italic">AI 转型之旅了吗？</span>
        </h2>
        <p class="text-gray-400 text-lg mb-12 max-w-2xl mx-auto">
          无论是遗留系统改造、还是专业软件深度适配，我们都准备好为您交付“确定性”的 AI 生产力。
        </p>
        <div class="flex justify-center flex-wrap gap-6">
          <a href="mailto:xie.james@hotmail.com" class="px-12 py-5 bg-gold text-dark font-black tracking-widest text-lg hover:scale-105 transition-all shadow-[0_0_30px_rgba(212,175,55,0.3)]">
            立即开启合作
          </a>
          <a href="/" class="px-12 py-5 border-2 border-white/20 text-white font-bold text-lg hover:bg-white/10 transition-all">
            返回首页
          </a>
        </div>
      </div>
      
      <!-- Subtle artistic touch -->
      <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-gold/5 blur-[150px] rotate-12"></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
