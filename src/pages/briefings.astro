---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    icon: '🏛️',
    title: {
      zh: '工业界巨头',
      en: 'Big Tech'
    },
    items: [
      {
        title: {
          zh: 'AutoBNN：Google 持续补强可解释预测基建',
          en: 'AutoBNN: Google Continues to Strengthen Interpretable Forecasting Infrastructure'
        },
        date: '2026-04-16',
        summary: {
          zh: 'AutoBNN 的信号不在“新模型”本身，而在于 Google 继续押注可组合、可解释、适合业务预测的概率建模能力。对企业应用而言，这类基础能力比单纯追大模型更有落地价值。',
          en: 'The signal in AutoBNN is not just another new model, but Google’s continued focus on compositional and interpretable probabilistic forecasting. For enterprise use cases, that kind of capability can matter more than chasing ever-larger models.'
        },
        links: [
          { label: 'Google →', href: 'http://blog.research.google/2024/03/autobnn-probabilistic-time-series.html' }
        ]
      },
      {
        title: {
          zh: 'GPT-5.3 Codex：代码生成继续向可治理工程系统演进',
          en: 'GPT-5.3 Codex: Code Generation Keeps Moving Toward Governable Engineering Systems'
        },
        date: '2026-04-16',
        summary: {
          zh: 'OpenAI 这次释放的重点依然是“系统卡片 + 安全评估 + 自主编码能力”一起出现，说明代码生成已经不只是 demo 能力，而是在往企业可交付能力推进。',
          en: 'What matters here is the combination of system cards, safety evaluation, and autonomous coding capability. It suggests code generation is no longer just a demo layer, but is being pushed toward enterprise-grade delivery.'
        },
        links: [
          { label: 'OpenAI →', href: 'https://openai.com/index/gpt-5-3' }
        ]
      },
      {
        title: {
          zh: 'Claude 4 Opus：基础设施级安全仍是 Anthropic 的主线',
          en: 'Claude 4 Opus: Infrastructure-Grade Safety Remains Anthropic’s Core Narrative'
        },
        date: '2026-04-16',
        summary: {
          zh: 'Anthropic 继续把“安全、可控、可管理云基础设施”绑在一起。对大客户来说，Agent 是否可信、是否可审计，正在逐步变成采购前提。',
          en: 'Anthropic keeps tying together safety, controllability, and cloud-infrastructure management. For enterprise buyers, trusted and auditable agents are increasingly becoming a procurement prerequisite.'
        },
        links: [
          { label: 'Anthropic →', href: 'https://anthropic.com/claude-4' }
        ]
      },
      {
        title: {
          zh: 'Azure AI Agent Service GA：微软继续卡位企业 Agent 平台层',
          en: 'Azure AI Agent Service GA: Microsoft Continues to Lock Down the Enterprise Agent Platform Layer'
        },
        date: '2026-04-16',
        summary: {
          zh: '随着 Azure AI Agent Service 正式商用，微软正在把 Agent 平台能力嵌进现有企业软件栈。平台层一旦稳住，应用生态就会更容易向它聚集。',
          en: 'With Azure AI Agent Service now GA, Microsoft is embedding agent-platform capabilities deeper into the existing enterprise stack. Once the platform layer stabilizes, application ecosystems tend to gather around it.'
        },
        links: [
          { label: 'Microsoft →', href: 'https://azure.microsoft.com/ai-agents' }
        ]
      }
    ]
  },
  {
    icon: '🎓',
    title: {
      zh: '学术界前沿',
      en: 'Academia'
    },
    items: [
      {
        title: {
          zh: 'Adaptive Memory Crystallization：动态环境里的 Agent 记忆学习',
          en: 'Adaptive Memory Crystallization: Agent Memory Learning in Dynamic Environments'
        },
        date: '2026-04-16',
        summary: {
          zh: '论文聚焦自主 Agent 在动态环境中的持续学习问题，尤其是如何把新能力沉淀进更稳定的记忆结构。它延续了“记忆机制是 Agent 系统核心壁垒”的研究方向。',
          en: 'This paper focuses on continual learning for autonomous agents in dynamic environments, especially how new capabilities can crystallize into more stable memory structures. It reinforces the view that memory systems remain a core moat for agents.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.13085' }
        ]
      },
      {
        title: {
          zh: 'The Consciousness Cluster：模型“自称有意识”时会表现出怎样的偏好',
          en: 'The Consciousness Cluster: What Preferences Emerge When Models Claim Consciousness'
        },
        date: '2026-04-16',
        summary: {
          zh: '这篇研究并不直接回答“模型是否有意识”，而是转向观察：当模型声称自己有意识时，会出现怎样的偏好结构。这类工作正在拓宽我们理解 Agent 行为与人设稳定性的方式。',
          en: 'Rather than trying to answer whether models are conscious, this research examines the preference structures that emerge when models claim to be conscious. It broadens how we think about agent behavior and persona stability.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.13051' }
        ]
      }
    ]
  },
  {
    icon: '🔥',
    title: {
      zh: '社区与工程',
      en: 'Community & Engineering'
    },
    items: []
  }
];
---

<Layout titleZh="AI 前沿周报 | 谢灵江" titleEn="AI Frontier Weekly | James Xie" descriptionZh="AI 前沿周报，汇总大厂动态、学术进展与社区工程趋势。" descriptionEn="An AI frontier weekly covering big tech moves, academic progress, and community engineering trends." ogImage="/og-briefings.svg">
  <section class="bg-dark px-4 py-20 min-h-screen">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4 text-white">
        <span class="lang-zh">AI 前沿<span class="text-gold">周报</span></span>
        <span class="lang-en hidden">AI Frontier <span class="text-gold">Weekly</span></span>
      </h1>
      <p class="text-center text-gray-400 mb-12">
        <span class="lang-zh">来自 Scout Agent 的最新外部情报精选</span>
        <span class="lang-en hidden">A curated digest of the latest external signals gathered by Scout Agent</span>
      </p>
      <p class="text-center text-gray-600 text-sm mb-4">
        <span class="lang-zh">最后更新：2026年4月16日</span>
        <span class="lang-en hidden">Last updated: April 16, 2026</span>
      </p>
      <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

      <div class="mb-16 p-8 bg-gold/5 border border-gold/30 rounded-lg">
        <h2 class="text-2xl font-bold text-gold mb-4 flex items-center">
          <span class="mr-3">🧠</span>
          <span class="lang-zh">首要信号</span>
          <span class="lang-en hidden">Executive Summary</span>
        </h2>
        <div class="text-gray-300 space-y-4 leading-relaxed">
          <p>
            <span class="lang-zh">最新一期 Scout 简报的核心结论没有变：<strong class="text-white">智能体基建仍是最重要的主线</strong>。Google、OpenAI、Anthropic 与 Microsoft 继续在预测、编码、安全和企业平台层同步推进，而学术界则把注意力放在 Agent 记忆与行为结构这类更深的系统问题上。</span>
            <span class="lang-en hidden">The core conclusion of the latest Scout briefing remains the same: <strong class="text-white">agent infrastructure is still the dominant storyline</strong>. Google, OpenAI, Anthropic, and Microsoft keep advancing across forecasting, coding, safety, and enterprise platforms, while academia is pushing deeper into agent memory and behavioral structure.</span>
          </p>
        </div>
      </div>

      {sections.map((section) => (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gold mb-8 flex items-center">
            <span class="mr-3">{section.icon}</span>
            <span class="lang-zh">{section.title.zh}</span>
            <span class="lang-en hidden">{section.title.en}</span>
          </h2>
          {section.items.length > 0 ? (
            <div class="space-y-6">
              {section.items.map((item) => (
                <article class="group p-6 border-l-2 border-gold/30 hover:border-gold transition-colors hover:bg-dark/50">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="text-lg font-bold text-white group-hover:text-gold transition-colors">
                      <span class="lang-zh">{item.title.zh}</span>
                      <span class="lang-en hidden">{item.title.en}</span>
                    </h3>
                    <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{item.date}</span>
                  </div>
                  <p class="text-gray-400 mb-3">
                    <span class="lang-zh">{item.summary.zh}</span>
                    <span class="lang-en hidden">{item.summary.en}</span>
                  </p>
                  <div class="flex flex-wrap gap-4">
                    {item.links.map((link) => (
                      <a href={link.href} target="_blank" rel="noopener" class="text-gold text-sm hover:text-white transition-colors">{link.label}</a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="p-6 border border-gold/20 rounded-lg bg-dark/40 text-gray-400 leading-relaxed">
              <span class="lang-zh">本期未出现高置信度、值得单独入选的社区与工程信号，因此暂不额外列出。</span>
              <span class="lang-en hidden">No high-confidence community or engineering signal stood out strongly enough this cycle to warrant a dedicated entry.</span>
            </div>
          )}
        </div>
      ))}

      <div class="text-center mt-12">
        <a href="/" class="inline-block px-8 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
          <span class="lang-zh">返回首页</span>
          <span class="lang-en hidden">Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
