---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    icon: '🏛️',
    title: {
      zh: '工业界巨头',
      en: 'Big Tech'
    },
    items: [
      {
        title: {
          zh: 'AWS Bedrock AgentCore：几分钟内构建你的第一个 Agent',
          en: 'AWS Bedrock AgentCore: Build Your First Agent in Minutes'
        },
        date: '2026-04-22',
        summary: {
          zh: 'AWS 推出 Bedrock AgentCore 新功能，大幅简化 Agent 构建体验，移除从开发到部署各阶段的基建障碍，让团队能够快速将 Agent 从概念转化为实际生产力。',
          en: 'AWS introduces new capabilities in Bedrock AgentCore that streamline the agent building experience, removing infrastructure barriers at every stage from development to deployment, enabling teams to rapidly transform agents from concept to production.'
        },
        links: [
          { label: 'AWS →', href: 'https://aws.amazon.com/blogs/machine-learning/get-to-your-first-working-agent-in-minutes-announcing-new-features-in-amazon-bedrock-agentcore/' }
        ]
      },
      {
        title: {
          zh: 'OpenAI GPT-5.5：更智能、更快速的前沿模型',
          en: 'OpenAI GPT-5.5: The Smartest Model Yet'
        },
        date: '2026-04-23',
        summary: {
          zh: 'GPT-5.5 是 OpenAI 迄今为止最智能的模型，在编码、研究和数据分析等复杂任务上展现出更强的能力，同时提供更快的推理速度和更优的工具调用能力。',
          en: 'GPT-5.5 is OpenAI\'s smartest model yet—faster, more capable, and built for complex tasks like coding, research, and data analysis across tools, representing a significant step forward in frontier model capabilities.'
        },
        links: [
          { label: 'OpenAI →', href: 'https://openai.com/index/introducing-gpt-5-5' }
        ]
      },
      {
        title: {
          zh: 'NVIDIA Jetson：最大化内存效率运行更大模型',
          en: 'NVIDIA Jetson: Maximizing Memory Efficiency for Larger Models'
        },
        date: '2026-04-20',
        summary: {
          zh: 'NVIDIA 推出在 Jetson 平台上运行更大开源生成式 AI 模型的内存优化技术，推动边缘端 AI 从数据中心走向物理世界的实际部署。',
          en: 'NVIDIA introduces memory optimization techniques for running larger open-source generative AI models on Jetson platforms, pushing edge AI deployment from data centers into the physical world.'
        },
        links: [
          { label: 'NVIDIA →', href: 'https://developer.nvidia.com/blog/maximizing-memory-efficiency-to-run-bigger-models-on-nvidia-jetson/' }
        ]
      },
      {
        title: {
          zh: 'Anthropic Claude 记忆 Bug 事后分析',
          en: 'Anthropic Postmortem: Claude\'s 60-Minute Memory Bug'
        },
        date: '2026-04-24',
        summary: {
          zh: 'Anthropic 发布工程事后分析报告，解释 Claude 因一个 Bug 导致推理能力在 60 分钟后消失的问题，展现了透明工程文化和对长期对话状态管理的挑战。',
          en: 'Anthropic publishes an engineering postmortem explaining a bug that caused Claude\'s reasoning capabilities to be erased after 60 minutes, highlighting the challenges of maintaining long-term conversational state in frontier models.'
        },
        links: [
          { label: 'HN →', href: 'https://news.ycombinator.com/item?id=47885022' }
        ]
      }
    ]
  },
  {
    icon: '📰',
    title: {
      zh: '顶级媒体',
      en: 'Top Media'
    },
    items: [
      {
        title: {
          zh: 'DeepSeek 预览新模型，缩小与前沿模型的差距',
          en: 'DeepSeek Previews New Model Closing Gap with Frontier Models'
        },
        date: '2026-04-24',
        summary: {
          zh: 'DeepSeek 宣布新模型在架构改进后，几乎"缩小了"与当前领先模型（无论是开源还是闭源）之间的差距，在效率和性能上均超越 DeepSeek V3.2。',
          en: 'DeepSeek announces new models with architectural improvements that have almost "closed the gap" with current leading models, both open and closed, outperforming DeepSeek V3.2 in efficiency and performance.'
        },
        links: [
          { label: 'TechCrunch →', href: 'https://techcrunch.com/2026/04/24/deepseek-previews-new-ai-model-that-closes-the-gap-with-frontier-models/' }
        ]
      },
      {
        title: {
          zh: 'Bret Taylor 的 Sierra 收购 YC 支持的 AI 初创公司 Fragment',
          en: 'Bret Taylor\'s Sierra Acquires YC-Backed AI Startup Fragment'
        },
        date: '2026-04-23',
        summary: {
          zh: '由技术专家 Bret Taylor 创立的 AI 客户智能体初创公司 Sierra 宣布收购 YC 支持的法国初创公司 Fragment，进一步整合 AI 客服领域的技术力量。',
          en: 'Sierra, the AI customer service agent startup founded by Bret Taylor, acquires YC-backed French startup Fragment, further consolidating technical capabilities in the AI customer service space.'
        },
        links: [
          { label: 'TechCrunch →', href: 'https://techcrunch.com/2026/04/23/bret-taylors-sierra-buys-yc-backed-ai-startup-fragment/' }
        ]
      }
    ]
  },
  {
    icon: '🎓',
    title: {
      zh: '学术界前沿',
      en: 'Academia'
    },
    items: [
      {
        title: {
          zh: 'Caesar：深度 Agent 网页探索与创意答案合成',
          en: 'Caesar: Deep Agentic Web Exploration for Creative Answer Synthesis'
        },
        date: '2026-04-24',
        summary: {
          zh: 'Caesar 提出从被动检索到创意发现的关键跃迁，让 Agent 能够进行深度关联合成，通过自主网页探索发现新想法，代表了 AI 研究范式的重大突破。',
          en: 'Caesar advances from passive retrieval to creative discovery, enabling agents to perform deep associative synthesis through autonomous web exploration, representing a major breakthrough in AI research paradigms.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.20855' }
        ]
      },
      {
        title: {
          zh: 'DR-Venus：仅用 1 万开源数据构建边缘端深度研究 Agent',
          en: 'DR-Venus: Frontier Edge-Scale Deep Research Agents with Only 10K Open Data'
        },
        date: '2026-04-24',
        summary: {
          zh: 'DR-Venus 证明仅用 1 万条开源数据就能训练出边缘端深度研究 Agent，在成本、延迟和隐私保护方面具有显著优势，为实时部署提供了极具吸引力的方案。',
          en: 'DR-Venus demonstrates that frontier deep research agents can be built with only 10K open data points, offering significant advantages in cost, latency, and privacy for real-world edge deployment scenarios.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.19859' }
        ]
      },
      {
        title: {
          zh: 'Agentic AI：热带城市热岛效应与建筑能源评估框架',
          en: 'Agentic AI for Thermal Comfort and Building Energy Assessment'
        },
        date: '2026-04-24',
        summary: {
          zh: '针对新加坡城市热岛效应和建筑能源需求，提出基于 Agent 的推理框架，用于热带城市社区的热舒适度和建筑能源评估，展示了 AI 在可持续城市设计中的应用。',
          en: 'An agentic AI-enabled reasoning framework for thermal comfort and building energy assessment in response to urban heat island effects in Singapore, demonstrating AI applications in sustainable urban design.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.21787' }
        ]
      },
      {
        title: {
          zh: 'Co-Evolving：长周期任务的 LLM 决策与技能库 Agent',
          en: 'Co-Evolving LLM Decision and Skill Bank Agents for Long-Horizon Tasks'
        },
        date: '2026-04-24',
        summary: {
          zh: '针对长周期交互环境中的 Agent 技能使用能力，提出 LLM 决策与技能库协同进化的方法，为多步骤推理和复杂任务规划提供新的理论框架。',
          en: 'A co-evolution approach for LLM decision-making and skill bank agents in long-horizon interactive environments, providing a new theoretical framework for multi-step reasoning and complex task planning.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.20987' }
        ]
      },
      {
        title: {
          zh: 'HypEHR：电子健康记录的双曲建模',
          en: 'HypEHR: Hyperbolic Modeling of Electronic Health Records'
        },
        date: '2026-04-24',
        summary: {
          zh: '利用双曲几何对电子健康记录进行建模，实现更高效的问答推理，为医疗 AI 提供了一种不同于传统 LLM 管道的低成本替代方案。',
          en: 'Hyperbolic modeling of electronic health records for efficient question answering, providing a low-cost alternative to traditional LLM-based pipelines in medical AI.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.21027' }
        ]
      }
    ]
  },
  {
    icon: '🔥',
    title: {
      zh: '社区与工程',
      en: 'Community & Engineering'
    },
    items: [
      {
        title: {
          zh: 'DeepSeek-V4：Agent 真正可用的百万 token 上下文',
          en: 'DeepSeek-V4: A Million-Token Context Agents Can Actually Use'
        },
        date: '2026-04-24',
        summary: {
          zh: 'DeepSeek-V4 实现了真正的百万 token 上下文窗口，不仅是在简单记忆测试中，而是在 Agent 实际工作场景中能够有效利用的超长上下文，为复杂任务处理开辟了新可能。',
          en: 'DeepSeek-V4 achieves a true million-token context window—not just in needle-in-haystack tests, but in practical agent workflows—opening new possibilities for handling extremely complex tasks with massive information requirements.'
        },
        links: [
          { label: 'Hugging Face →', href: 'https://huggingface.co/blog/deepseekv4' }
        ]
      },
      {
        title: {
          zh: 'Transformers.js 在 Chrome 扩展中的应用',
          en: 'Using Transformers.js in Chrome Extensions'
        },
        date: '2026-04-23',
        summary: {
          zh: 'Hugging Face 发布教程，展示如何在 Chrome 扩展中使用 Transformers.js，让开发者能够在浏览器端直接运行 AI 模型，实现本地化、隐私保护的 AI 功能。',
          en: 'Hugging Face publishes a tutorial on using Transformers.js in Chrome extensions, enabling developers to run AI models directly in the browser for localized, privacy-preserving AI features.'
        },
        links: [
          { label: 'Hugging Face →', href: 'https://huggingface.co/blog/transformersjs-chrome-extension' }
        ]
      },
      {
        title: {
          zh: 'NVIDIA：用生成式 AI 辅助编程赢得 Kaggle 竞赛',
          en: 'Winning Kaggle Competitions with Generative AI-Assisted Coding'
        },
        date: '2026-04-23',
        summary: {
          zh: '三个 LLM Agent 生成了超过 60 万行代码，运行了 850 次实验，帮助团队在 2026 年 3 月的 Kaggle 竞赛中获得第一名，展示了 AI 辅助编程的实际威力。',
          en: 'Three LLM agents generated over 600,000 lines of code, ran 850 experiments, and helped secure first place in a March 2026 Kaggle competition, demonstrating the real power of AI-assisted programming.'
        },
        links: [
          { label: 'NVIDIA →', href: 'https://developer.nvidia.com/blog/winning-a-kaggle-competition-with-generative-ai-assisted-coding/' }
        ]
      }
    ]
  }
];
---

<Layout titleZh="AI 前沿周报 | 谢灵江" titleEn="AI Frontier Weekly | James Xie" descriptionZh="AI 前沿周报，汇总大厂动态、学术进展与社区工程趋势。" descriptionEn="An AI frontier weekly covering big tech moves, academic progress, and community engineering trends." ogImage="/og-briefings.svg">
  <section class="bg-dark px-4 py-20 min-h-screen">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4 text-white">
        <span class="lang-zh">AI 前沿<span class="text-gold">周报</span></span>
        <span class="lang-en hidden">AI Frontier <span class="text-gold">Weekly</span></span>
      </h1>
      <p class="text-center text-gray-400 mb-12">
        <span class="lang-zh">来自 Scout Agent 的最新外部情报精选</span>
        <span class="lang-en hidden">A curated digest of the latest external signals gathered by Scout Agent</span>
      </p>
      <p class="text-center text-gray-600 text-sm mb-4">
        <span class="lang-zh">最后更新：2026年05月09日</span>
        <span class="lang-en hidden">Last updated: May 09, 2026
      </p>
      <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

      <div class="mb-16 p-8 bg-gold/5 border border-gold/30 rounded-lg">
        <h2 class="text-2xl font-bold text-gold mb-4 flex items-center">
          <span class="mr-3">🧠</span>
          <span class="lang-zh">首要信号</span>
          <span class="lang-en hidden">Executive Summary</span>
        </h2>
        <div class="text-gray-300 space-y-4 leading-relaxed">
          <p>
            <span class="lang-zh">今日实时抓取的 Scout 简报显示，<strong class="text-white">"Agent Infrastructure"与"模型效率"</strong>成为本周技术锚点。AWS 推出 Bedrock AgentCore 简化 Agent 构建，OpenAI 发布 GPT-5.5 强化复杂任务能力，而学术界在深度研究 Agent 和边缘端部署上取得突破性进展。DeepSeek-V4 的百万 token 上下文则为超长上下文实际应用提供了新可能。</span>
            <span class="lang-en hidden">Real-time signals from today's Scout briefing highlight <strong class="text-white">"Agent Infrastructure" and "Model Efficiency"</strong> as this week's technological anchors. AWS simplifies agent building with Bedrock AgentCore, OpenAI releases GPT-5.5 for complex tasks, while academia makes breakthroughs in deep research agents and edge deployment. DeepSeek-V4's million-token context opens new possibilities for practical ultra-long context applications.</span>
          </p>
        </div>
      </div>

      {sections.map((section) => (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gold mb-8 flex items-center">
            <span class="mr-3">{section.icon}</span>
            <span class="lang-zh">{section.title.zh}</span>
            <span class="lang-en hidden">{section.title.en}</span>
          </h2>
          {section.items.length > 0 ? (
            <div class="space-y-6">
              {section.items.map((item) => (
                <article class="group p-6 border-l-2 border-gold/30 hover:border-gold transition-colors hover:bg-dark/50">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="text-lg font-bold text-white group-hover:text-gold transition-colors">
                      <span class="lang-zh">{item.title.zh}</span>
                      <span class="lang-en hidden">{item.title.en}</span>
                    </h3>
                    <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{item.date}</span>
                  </div>
                  <p class="text-gray-400 mb-3">
                    <span class="lang-zh">{item.summary.zh}</span>
                    <span class="lang-en hidden">{item.summary.en}</span>
                  </p>
                  <div class="flex flex-wrap gap-4">
                    {item.links.map((link) => (
                      <a href={link.href} target="_blank" rel="noopener" class="text-gold text-sm hover:text-white transition-colors">{link.label}</a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="p-6 border border-gold/20 rounded-lg bg-dark/40 text-gray-400 leading-relaxed">
              <span class="lang-zh">本期未出现高置信度、值得单独入选的社区与工程信号，因此暂不额外列出。</span>
              <span class="lang-en hidden">No high-confidence community or engineering signal stood out strongly enough this cycle to warrant a dedicated entry.</span>
            </div>
          )}
        </div>
      ))}

      <div class="text-center mt-12">
        <a href="/" class="inline-block px-8 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
          <span class="lang-zh">返回首页</span>
          <span class="lang-en hidden">Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
