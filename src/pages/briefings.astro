---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    icon: '🏛️',
    title: {
      zh: '工业界巨头',
      en: 'Big Tech'
    },
    items: [
      {
        title: {
          zh: 'Amazon Nova：多模态嵌入驱动视频语义搜索',
          en: 'Amazon Nova: Driving Video Semantic Search with Multimodal Embeddings'
        },
        date: '2026-04-20',
        summary: {
          zh: 'AWS 推出的 Nova 多模态嵌入模型能够深度理解视频内容，支持复杂的语义检索。这标志着云服务商正在将 AI 能力从文本/图片进一步下沉到视频资产层。',
          en: 'AWS\'s Nova Multimodal Embeddings deeply understand video content, enabling complex semantic retrieval. This marks cloud providers pushing AI capabilities deeper into the video asset layer.'
        },
        links: [
          { label: 'AWS →', href: 'https://aws.amazon.com/blogs/machine-learning/power-video-semantic-search-with-amazon-nova-multimodal-embeddings/' }
        ]
      },
      {
        title: {
          zh: 'NVIDIA NemoClaw：本地安全智能体的新标杆',
          en: 'NVIDIA NemoClaw: A New Benchmark for Secure Local Agents'
        },
        date: '2026-04-20',
        summary: {
          zh: 'NVIDIA 配合 OpenClaw 推出 NemoClaw，旨在构建“常驻、安全、自主”的本地 AI 智能体。这对重视数据隐私的企业级本地化部署具有重要战略意义。',
          en: 'NVIDIA launched NemoClaw alongside OpenClaw, aiming for "always-on, secure, autonomous" local AI agents. This is strategically vital for enterprise-grade on-premise deployments valuing data privacy.'
        },
        links: [
          { label: 'NVIDIA →', href: 'https://developer.nvidia.com/blog/build-a-secure-always-on-local-ai-agent-with-nvidia-nemoclaw-and-openclaw/' }
        ]
      },
      {
        title: {
          zh: 'OpenAI GPT-Rosalind：推理模型深耕垂直科学领域',
          en: 'OpenAI GPT-Rosalind: Reasoning Models Deepening Vertical Science'
        },
        date: '2026-04-16',
        summary: {
          zh: 'GPT-Rosalind 的推出预示着通用大模型厂商正在通过强化推理能力，切入医药研发、蛋白质科学等高门槛垂直行业。',
          en: 'The launch of GPT-Rosalind signals general-purpose model vendors moving into high-barrier vertical industries like drug R&D and protein science through enhanced reasoning.'
        },
        links: [
          { label: 'OpenAI →', href: 'https://openai.com/index/introducing-gpt-rosalind' }
        ]
      }
    ]
  },
  {
    icon: '🎓',
    title: {
      zh: '学术界前沿',
      en: 'Academia'
    },
    items: [
      {
        title: {
          zh: 'DeepER-Med：智能体 AI 驱动的证据医学研究',
          en: 'DeepER-Med: Agentic AI for Evidence-Based Medical Research'
        },
        date: '2026-04-20',
        summary: {
          zh: '该研究展示了如何利用 Agent 架构提升医学研究的可信度与透明度，是 AI 进入严肃医疗决策领域的重要探索。',
          en: 'This research demonstrates using agentic architectures to enhance the trustworthiness and transparency of medical research, a key step for AI in serious medical decision-making.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.15456' }
        ]
      },
      {
        title: {
          zh: 'NeuroMesh：多机器人去中心化协作推理',
          en: 'NeuroMesh: Decentralized Collaborative Inference for Multi-Robots'
        },
        date: '2026-04-20',
        summary: {
          zh: 'NeuroMesh 解决了异构机器人在通信受限环境下的协同问题，为未来大规模机器人集群的智能化调度提供了统一框架。',
          en: 'NeuroMesh addresses coordination for heterogeneous robots in communication-constrained environments, providing a unified framework for future large-scale robot swarm scheduling.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.15475' }
        ]
      }
    ]
  },
  {
    icon: '🔥',
    title: {
      zh: '社区与工程',
      en: 'Community & Engineering'
    },
    items: [
      {
        title: {
          zh: 'IBM VAKRA：解析 Agent 失败模式与推理逻辑',
          en: 'IBM VAKRA: Analyzing Agent Failure Modes and Reasoning Logic'
        },
        date: '2026-04-15',
        summary: {
          zh: '通过 VAKRA 基准，社区得以深入理解 Agent 在复杂工具调用中的薄弱环节，为下一代更鲁棒的 Agent 开发指明方向。',
          en: 'Through the VAKRA benchmark, the community gains a deep understanding of agent weaknesses in complex tool calls, guiding the development of more robust agents.'
        },
        links: [
          { label: 'Hugging Face →', href: 'https://huggingface.co/blog/ibm-research/vakra-benchmark-analysis' }
        ]
      }
    ]
  }
];
---

<Layout titleZh="AI 前沿周报 | 谢灵江" titleEn="AI Frontier Weekly | James Xie" descriptionZh="AI 前沿周报，汇总大厂动态、学术进展与社区工程趋势。" descriptionEn="An AI frontier weekly covering big tech moves, academic progress, and community engineering trends." ogImage="/og-briefings.svg">
  <section class="bg-dark px-4 py-20 min-h-screen">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4 text-white">
        <span class="lang-zh">AI 前沿<span class="text-gold">周报</span></span>
        <span class="lang-en hidden">AI Frontier <span class="text-gold">Weekly</span></span>
      </h1>
      <p class="text-center text-gray-400 mb-12">
        <span class="lang-zh">来自 Scout Agent 的最新外部情报精选</span>
        <span class="lang-en hidden">A curated digest of the latest external signals gathered by Scout Agent</span>
      </p>
      <p class="text-center text-gray-600 text-sm mb-4">
        <span class="lang-zh">最后更新：2026年4月20日</span>
        <span class="lang-en hidden">Last updated: April 20, 2026</span>
      </p>
      <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

      <div class="mb-16 p-8 bg-gold/5 border border-gold/30 rounded-lg">
        <h2 class="text-2xl font-bold text-gold mb-4 flex items-center">
          <span class="mr-3">🧠</span>
          <span class="lang-zh">首要信号</span>
          <span class="lang-en hidden">Executive Summary</span>
        </h2>
        <div class="text-gray-300 space-y-4 leading-relaxed">
          <p>
            <span class="lang-zh">今日实时抓取的 Scout 简报显示，<strong class="text-white">“多模态深化”与“本地化 Agent”</strong>正成为新的技术锚点。Amazon 通过 Nova 将语义搜索推进至视频层，NVIDIA 则通过 NemoClaw 强化了本地安全智能体的部署能力。同时，医疗和机器人领域的垂直化 Agent 研究也正步入深水区。</span>
            <span class="lang-en hidden">Real-time signals from today's Scout briefing highlight <strong class="text-white">"Multimodal Deepening" and "Local Agentization"</strong> as new technological anchors. Amazon is pushing semantic search to the video layer via Nova, while NVIDIA strengthens local secure agent deployment through NemoClaw. Vertical agent research in medical and robotics sectors is also entering a more advanced stage.</span>
          </p>
        </div>
      </div>

      {sections.map((section) => (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gold mb-8 flex items-center">
            <span class="mr-3">{section.icon}</span>
            <span class="lang-zh">{section.title.zh}</span>
            <span class="lang-en hidden">{section.title.en}</span>
          </h2>
          {section.items.length > 0 ? (
            <div class="space-y-6">
              {section.items.map((item) => (
                <article class="group p-6 border-l-2 border-gold/30 hover:border-gold transition-colors hover:bg-dark/50">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="text-lg font-bold text-white group-hover:text-gold transition-colors">
                      <span class="lang-zh">{item.title.zh}</span>
                      <span class="lang-en hidden">{item.title.en}</span>
                    </h3>
                    <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{item.date}</span>
                  </div>
                  <p class="text-gray-400 mb-3">
                    <span class="lang-zh">{item.summary.zh}</span>
                    <span class="lang-en hidden">{item.summary.en}</span>
                  </p>
                  <div class="flex flex-wrap gap-4">
                    {item.links.map((link) => (
                      <a href={link.href} target="_blank" rel="noopener" class="text-gold text-sm hover:text-white transition-colors">{link.label}</a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="p-6 border border-gold/20 rounded-lg bg-dark/40 text-gray-400 leading-relaxed">
              <span class="lang-zh">本期未出现高置信度、值得单独入选的社区与工程信号，因此暂不额外列出。</span>
              <span class="lang-en hidden">No high-confidence community or engineering signal stood out strongly enough this cycle to warrant a dedicated entry.</span>
            </div>
          )}
        </div>
      ))}

      <div class="text-center mt-12">
        <a href="/" class="inline-block px-8 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
          <span class="lang-zh">返回首页</span>
          <span class="lang-en hidden">Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
