<Layout title="AI 前沿周报" description="每日 AI 技术情报汇总">
  <main class="min-h-screen bg-dark text-white">
    <section class="py-16 px-4">
      <div class="max-w-5xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-12">
          <h1 class="text-5xl font-bold mb-4">
            AI 前沿<span class="text-gold">周报</span>
          </h1>
          <p class="text-gray-400 text-lg">最后更新：{generatedDate}</p>
          <div class="h-1 w-24 bg-gold mx-auto mt-6"></div>
        </div>

        <!-- Content Sections -->
        {sections.map((section) => (
          <div class="mb-16">
            <h2 class="text-3xl font-bold mb-8 flex items-center">
              <span class="mr-3">{section.icon}</span>
              <span class="lang-zh">{section.title.zh}</span>
              <span class="lang-en hidden">{section.title.en}</span>
            </h2>
            
            <div class="space-y-4">
              {section.items.map((item) => (
                <article class="group p-6 border-l-2 border-gold/30 hover:border-gold transition-colors hover:bg-dark/50">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="text-xl font-bold text-white group-hover:text-gold transition-colors lang-zh">
                      {item.title.zh}
                    </h3>
                    <h3 class="text-xl font-bold text-white group-hover:text-gold transition-colors lang-en hidden">
                      {item.title.en}
                    </h3>
                    <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{item.date}</span>
                  </div>
                  
                  <p class="text-gray-400 mb-4 lang-zh">{item.summary.zh}</p>
                  <p class="text-gray-400 mb-4 lang-en hidden">{item.summary.en}</p>
                  
                  <div class="flex flex-wrap gap-4">
                    {item.links.map((link) => (
                      <a href={link.href} target="_blank" rel="noopener" class="text-gold text-sm hover:text-white transition-colors">
                        {link.label}
                      </a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}

        <!-- Back to Home -->
        <div class="text-center mt-16">
          <a href="/" class="inline-block px-8 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
            返回首页
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>