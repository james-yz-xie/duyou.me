---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    icon: '🏛️',
    title: {
      zh: '工业界巨头',
      en: 'Big Tech'
    },
    items: [
      {
        title: {
          zh: 'NVIDIA MiniMax M2.7：大规模智能体工作流调度加速',
          en: 'NVIDIA MiniMax M2.7: Accelerating Large-Scale Agentic Workflow Orchestration'
        },
        date: '2026-04-17',
        summary: {
          zh: 'NVIDIA MiniMax M2.7 强化了智能体调度框架，旨在 NVIDIA 平台上更高效地构建和运行复杂的 AI 智能体流水线。',
          en: 'NVIDIA MiniMax M2.7 enhances the agentic harness, designed for more efficient building and running of complex AI agent pipelines on NVIDIA platforms.'
        },
        links: [
          { label: 'NVIDIA →', href: 'https://developer.nvidia.com/blog/minimax-m2-7-advances-scalable-agentic-workflows-on-nvidia-platforms-for-complex-ai-applications/' }
        ]
      },
      {
        title: {
          zh: 'OpenAI GPT-Rosalind：推理模型进军生命科学',
          en: 'OpenAI GPT-Rosalind: Reasoning Models Enter Life Sciences'
        },
        date: '2026-04-17',
        summary: {
          zh: 'GPT-Rosalind 是专门为加速药物研发、蛋白质推理等复杂科学工作流而设计的推理模型，标志着 OpenAI 在垂直行业深耕的决心。',
          en: 'GPT-Rosalind is a reasoning model specifically designed to accelerate complex scientific workflows like drug discovery and protein reasoning, marking OpenAI\'s commitment to vertical industries.'
        },
        links: [
          { label: 'OpenAI →', href: 'https://openai.com/index/introducing-gpt-rosalind' }
        ]
      },
      {
        title: {
          zh: 'Gemini Robotics-ER 1.6：具身推理能力显著提升',
          en: 'Gemini Robotics-ER 1.6: Significant Boost in Embodied Reasoning'
        },
        date: '2026-04-17',
        summary: {
          zh: 'Google DeepMind 通过 Gemini Robotics-ER 1.6 增强了机器人的空间推理和多视图理解能力，进一步缩小了 AI 与物理世界交互的鸿沟。',
          en: 'Google DeepMind has enhanced spatial reasoning and multi-view understanding in robotics through Gemini Robotics-ER 1.6, further closing the gap between AI and physical interaction.'
        },
        links: [
          { label: 'Google →', href: 'https://deepmind.google/blog/gemini-robotics-er-1-6/' }
        ]
      },
      {
        title: {
          zh: 'AutoBNN：Google 持续补强可解释预测基建',
          en: 'AutoBNN: Google Continues to Strengthen Interpretable Forecasting Infrastructure'
        },
        date: '2026-04-16',
        summary: {
          zh: 'AutoBNN 的信号不在“新模型”本身，而在于 Google 继续押注可组合、可解释、适合业务预测的概率建模能力。',
          en: 'The signal in AutoBNN is not just another new model, but Google’s continued focus on compositional and interpretable probabilistic forecasting.'
        },
        links: [
          { label: 'Google →', href: 'http://blog.research.google/2024/03/autobnn-probabilistic-time-series.html' }
        ]
      }
    ]
  },
  {
    icon: '🎓',
    title: {
      zh: '学术界前沿',
      en: 'Academia'
    },
    items: [
      {
        title: {
          zh: 'TopoDIM：一步生成的智能体协作拓扑优化',
          en: 'TopoDIM: One-shot Topology Generation for Multi-Agent Collaboration'
        },
        date: '2026-04-17',
        summary: {
          zh: 'TopoDIM 提出了一种优化多智能体系统通信拓扑的新方法，能有效提升群体智能在大模型背景下的协作效率。',
          en: 'TopoDIM proposes a new method for optimizing communication topology in multi-agent systems, effectively improving collaborative efficiency in the LLM era.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2601.10120' }
        ]
      },
      {
        title: {
          zh: 'Exploration and Exploitation Errors：Agent 误差可测量化',
          en: 'Exploration and Exploitation Errors: Making Agent Errors Measurable'
        },
        date: '2026-04-17',
        summary: {
          zh: '该研究为大模型 Agent 在开放决策任务中的探索与利用误差提供了测量框架，是 Agent 走向工程化评估的重要一步。',
          en: 'This research provides a measurement framework for exploration and exploitation errors in LLM agents, a key step toward engineering-grade evaluation.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.13151' }
        ]
      }
    ]
  },
  {
    icon: '🔥',
    title: {
      zh: '社区与工程',
      en: 'Community & Engineering'
    },
    items: [
      {
        title: {
          zh: 'IBM VAKRA：深入解析智能体推理与失败模式',
          en: 'IBM VAKRA: Deep Dive into Agent Reasoning and Failure Modes'
        },
        date: '2026-04-17',
        summary: {
          zh: '通过 VAKRA 基准测试，IBM 揭示了当前 Agent 在工具使用和推理过程中的典型失败模式，为提升 Agent 鲁棒性提供了参考。',
          en: 'Through the VAKRA benchmark, IBM reveals typical failure modes of current agents in tool use and reasoning, providing a reference for improving robustness.'
        },
        links: [
          { label: 'Hugging Face →', href: 'https://huggingface.co/blog/ibm-research/vakra-benchmark-analysis' }
        ]
      }
    ]
  }
];
---

<Layout titleZh="AI 前沿周报 | 谢灵江" titleEn="AI Frontier Weekly | James Xie" descriptionZh="AI 前沿周报，汇总大厂动态、学术进展与社区工程趋势。" descriptionEn="An AI frontier weekly covering big tech moves, academic progress, and community engineering trends." ogImage="/og-briefings.svg">
  <section class="bg-dark px-4 py-20 min-h-screen">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4 text-white">
        <span class="lang-zh">AI 前沿<span class="text-gold">周报</span></span>
        <span class="lang-en hidden">AI Frontier <span class="text-gold">Weekly</span></span>
      </h1>
      <p class="text-center text-gray-400 mb-12">
        <span class="lang-zh">来自 Scout Agent 的最新外部情报精选</span>
        <span class="lang-en hidden">A curated digest of the latest external signals gathered by Scout Agent</span>
      </p>
      <p class="text-center text-gray-600 text-sm mb-4">
        <span class="lang-zh">最后更新：2026年4月20日</span>
        <span class="lang-en hidden">Last updated: April 20, 2026</span>
      </p>
      <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

      <div class="mb-16 p-8 bg-gold/5 border border-gold/30 rounded-lg">
        <h2 class="text-2xl font-bold text-gold mb-4 flex items-center">
          <span class="mr-3">🧠</span>
          <span class="lang-zh">首要信号</span>
          <span class="lang-en hidden">Executive Summary</span>
        </h2>
        <div class="text-gray-300 space-y-4 leading-relaxed">
          <p>
            <span class="lang-zh">本期 Scout 简报的核心信号集中在<strong class="text-white">“效率优化”与“边缘/本地 AI”</strong>。NVIDIA、OpenAI 与 Google 正在加速智能体（Agent）在复杂工作流和垂直行业（如机器人、生命科学）的落地，而学术界则开始建立更严谨的 Agent 性能测量框架。</span>
            <span class="lang-en hidden">The core signals of this Scout briefing focus on <strong class="text-white">"Efficiency & Optimization" and "Edge/Local AI"</strong>. NVIDIA, OpenAI, and Google are accelerating the deployment of agents in complex workflows and vertical industries, while academia has begun establishing more rigorous performance measurement frameworks for agents.</span>
          </p>
        </div>
      </div>

      {sections.map((section) => (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gold mb-8 flex items-center">
            <span class="mr-3">{section.icon}</span>
            <span class="lang-zh">{section.title.zh}</span>
            <span class="lang-en hidden">{section.title.en}</span>
          </h2>
          {section.items.length > 0 ? (
            <div class="space-y-6">
              {section.items.map((item) => (
                <article class="group p-6 border-l-2 border-gold/30 hover:border-gold transition-colors hover:bg-dark/50">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="text-lg font-bold text-white group-hover:text-gold transition-colors">
                      <span class="lang-zh">{item.title.zh}</span>
                      <span class="lang-en hidden">{item.title.en}</span>
                    </h3>
                    <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{item.date}</span>
                  </div>
                  <p class="text-gray-400 mb-3">
                    <span class="lang-zh">{item.summary.zh}</span>
                    <span class="lang-en hidden">{item.summary.en}</span>
                  </p>
                  <div class="flex flex-wrap gap-4">
                    {item.links.map((link) => (
                      <a href={link.href} target="_blank" rel="noopener" class="text-gold text-sm hover:text-white transition-colors">{link.label}</a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="p-6 border border-gold/20 rounded-lg bg-dark/40 text-gray-400 leading-relaxed">
              <span class="lang-zh">本期未出现高置信度、值得单独入选的社区与工程信号，因此暂不额外列出。</span>
              <span class="lang-en hidden">No high-confidence community or engineering signal stood out strongly enough this cycle to warrant a dedicated entry.</span>
            </div>
          )}
        </div>
      ))}

      <div class="text-center mt-12">
        <a href="/" class="inline-block px-8 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
          <span class="lang-zh">返回首页</span>
          <span class="lang-en hidden">Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
