---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    icon: '🏛️',
    title: {
      zh: '工业界巨头',
      en: 'Big Tech'
    },
    items: [
      {
        title: {
          zh: 'AutoBNN：Google 继续补强可组合时间序列预测',
          en: 'AutoBNN: Google Extends Compositional Time-Series Forecasting'
        },
        date: '2026-04-07',
        summary: {
          zh: 'Google 继续沿着“基础模型之外的基础设施”发力。AutoBNN 代表的是一类更可解释、更适合企业预测场景的概率建模能力。',
          en: 'Google continues pushing on the infrastructure beneath foundation models. AutoBNN points toward more interpretable probabilistic forecasting that fits real enterprise prediction workflows.'
        },
        links: [
          { label: 'Google →', href: 'http://blog.research.google/2024/03/autobnn-probabilistic-time-series.html' }
        ]
      },
      {
        title: {
          zh: 'GPT-5.3 Codex：代码生成能力继续向工程化落地推进',
          en: 'GPT-5.3 Codex: Code Generation Moves Closer to Engineering Deployment'
        },
        date: '2026-04-07',
        summary: {
          zh: '这次信号不只是“更会写代码”，而是系统卡片和安全评估一起出现，意味着 OpenAI 正把自主编码能力往可交付、可治理的方向推进。',
          en: 'The signal is not just better code generation. The system card and safety framing suggest OpenAI is moving autonomous coding toward something deployable and governable.'
        },
        links: [
          { label: 'OpenAI →', href: 'https://openai.com/index/gpt-5-3' }
        ]
      },
      {
        title: {
          zh: 'Claude 4 Opus：安全边界正在被重新定义为基础设施能力',
          en: 'Claude 4 Opus: Safety Boundaries Are Becoming Infrastructure Capabilities'
        },
        date: '2026-04-07',
        summary: {
          zh: 'Anthropic 继续把安全、可控和基础设施管理绑定在一起。对企业来说，这意味着“可信 Agent”正在从口号变成采购条件。',
          en: 'Anthropic keeps tying safety, control, and infrastructure management together. For enterprises, the trusted-agent story is becoming a procurement requirement rather than a slogan.'
        },
        links: [
          { label: 'Anthropic →', href: 'https://anthropic.com/claude-4' }
        ]
      },
      {
        title: {
          zh: 'Azure AI Agent Service GA：微软开始收割企业 Agent 平台层',
          en: 'Azure AI Agent Service GA: Microsoft Targets the Enterprise Agent Platform Layer'
        },
        date: '2026-04-07',
        summary: {
          zh: '从 Office 365 Copilot 到正式商用的 Agent Service，微软在把 Agent 变成企业 IT 的标准部件。谁掌握平台层，谁就更容易定义应用生态。',
          en: 'From Office 365 Copilot to GA agent services, Microsoft is turning agents into standard enterprise IT components. Whoever controls the platform layer is best positioned to shape the application ecosystem.'
        },
        links: [
          { label: 'Microsoft →', href: 'https://azure.microsoft.com/ai-agents' }
        ]
      }
    ]
  },
  {
    icon: '🎓',
    title: {
      zh: '学术界前沿',
      en: 'Academia'
    },
    items: [
      {
        title: {
          zh: 'SIEVE：自然语言上下文正在变成新的参数化学习接口',
          en: 'SIEVE: Natural Language Context Is Becoming a New Interface for Parametric Learning'
        },
        date: '2026-04-07',
        summary: {
          zh: '这项工作指出，指令、知识和反馈本身就能成为强学习信号。对于 Agent 系统，这意味着“上下文工程”正在接近“学习工程”。',
          en: 'This work shows that instructions, knowledge, and feedback can act as strong learning signals. For agent systems, context engineering is starting to converge with learning engineering.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.02339' }
        ]
      },
      {
        title: {
          zh: '单 Agent 优于多 Agent：多跳推理中的复杂度反思',
          en: 'Single Agent Beats Multi-Agent: A Complexity Check on Multi-Hop Reasoning'
        },
        date: '2026-04-07',
        summary: {
          zh: '在相同思考预算下，单 Agent LLM 在多跳推理中表现更优。这提醒我们，多 Agent 架构不能只追求“看起来更复杂”，还必须追问真实收益。',
          en: 'With equal thinking budgets, a single-agent LLM performs better on multi-hop reasoning. It is a reminder that multi-agent architectures should be judged by real gains, not by surface complexity.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.02460' }
        ]
      }
    ]
  },
  {
    icon: '🔥',
    title: {
      zh: '社区与工程',
      en: 'Community & Engineering'
    },
    items: [
      {
        title: {
          zh: 'LangChain + MongoDB：数据库正在演化为 Agent 默认底座',
          en: 'LangChain + MongoDB: Databases Are Evolving into the Default Agent Substrate'
        },
        date: '2026-04-07',
        summary: {
          zh: '向量搜索、持久记忆、自然语言查询和可观测性被统一打包，说明 Agent 技术栈正在摆脱零散拼装，开始形成更完整的平台底座。',
          en: 'Vector search, persistent memory, natural-language querying, and observability are being bundled together, showing how the agent stack is moving beyond ad hoc assembly toward a fuller platform foundation.'
        },
        links: [
          { label: 'LangChain →', href: 'https://blog.langchain.com/announcing-the-langchain-mongodb-partnership-the-ai-agent-stack-that-runs-on-the-database-you-already-trust/' }
        ]
      }
    ]
  }
];
---

<Layout titleZh="AI 前沿周报 | 谢灵江" titleEn="AI Frontier Weekly | James Xie" descriptionZh="AI 前沿周报，汇总大厂动态、学术进展与社区工程趋势。" descriptionEn="An AI frontier weekly covering big tech moves, academic progress, and community engineering trends." ogImage="/og-briefings.svg">
  <section class="bg-dark px-4 py-20 min-h-screen">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4 text-white">
        <span class="lang-zh">AI 前沿<span class="text-gold">周报</span></span>
        <span class="lang-en hidden">AI Frontier <span class="text-gold">Weekly</span></span>
      </h1>
      <p class="text-center text-gray-400 mb-12">
        <span class="lang-zh">来自 Scout Agent 的最新外部情报精选</span>
        <span class="lang-en hidden">A curated digest of the latest external signals gathered by Scout Agent</span>
      </p>
      <p class="text-center text-gray-600 text-sm mb-4">
        <span class="lang-zh">最后更新：2026年4月7日</span>
        <span class="lang-en hidden">Last updated: April 7, 2026</span>
      </p>
      <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

      <div class="mb-16 p-8 bg-gold/5 border border-gold/30 rounded-lg">
        <h2 class="text-2xl font-bold text-gold mb-4 flex items-center">
          <span class="mr-3">🧠</span>
          <span class="lang-zh">首要信号</span>
          <span class="lang-en hidden">Executive Summary</span>
        </h2>
        <div class="text-gray-300 space-y-4 leading-relaxed">
          <p>
            <span class="lang-zh">今天最强的信号集中在<strong class="text-white">智能体基建</strong>。Google、OpenAI、Anthropic 和 Microsoft 同时在预测、编码、安全与企业平台层加码，说明应用层创业者最该盯的，不再只是模型，而是围绕这些基建做组合创新与垂直落地。</span>
            <span class="lang-en hidden">The strongest signal this cycle is <strong class="text-white">agent infrastructure</strong>. Google, OpenAI, Anthropic, and Microsoft are all investing across forecasting, coding, safety, and enterprise platforms, suggesting that the next application opportunities will come from combination innovation and vertical execution on top of these layers.</span>
          </p>
        </div>
      </div>

      {sections.map((section) => (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gold mb-8 flex items-center">
            <span class="mr-3">{section.icon}</span>
            <span class="lang-zh">{section.title.zh}</span>
            <span class="lang-en hidden">{section.title.en}</span>
          </h2>
          <div class="space-y-6">
            {section.items.map((item) => (
              <article class="group p-6 border-l-2 border-gold/30 hover:border-gold transition-colors hover:bg-dark/50">
                <div class="flex justify-between items-start mb-3">
                  <h3 class="text-lg font-bold text-white group-hover:text-gold transition-colors">
                    <span class="lang-zh">{item.title.zh}</span>
                    <span class="lang-en hidden">{item.title.en}</span>
                  </h3>
                  <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{item.date}</span>
                </div>
                <p class="text-gray-400 mb-3">
                  <span class="lang-zh">{item.summary.zh}</span>
                  <span class="lang-en hidden">{item.summary.en}</span>
                </p>
                <div class="flex flex-wrap gap-4">
                  {item.links.map((link) => (
                    <a href={link.href} target="_blank" rel="noopener" class="text-gold text-sm hover:text-white transition-colors">{link.label}</a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}

      <div class="text-center mt-12">
        <a href="/" class="inline-block px-8 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
          <span class="lang-zh">返回首页</span>
          <span class="lang-en hidden">Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
