---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    icon: '🏛️',
    title: {
      zh: '工业界巨头',
      en: 'Big Tech'
    },
    items: [
      {
        title: {
          zh: '马斯克解散 xAI，22 万 GPU 超算租给 Anthropic',
          en: 'Musk Dissolves xAI, Rents 220K GPU Supercomputer to Anthropic'
        },
        date: '2026-05-06',
        summary: {
          zh: '马斯克宣布 xAI 正式解散并入 SpaceX，全球最大超算 Colossus 1（22 万张 GPU）全部出租给 Anthropic，年租金 50 亿美元。xAI 全年预计亏损 130 亿美元，Grok 利用率仅 11%。从模型竞赛者转型算力供应商。',
          en: 'Musk announces xAI dissolution into SpaceX, with the world\'s largest supercomputer Colossus 1 (220K GPUs) fully rented to Anthropic at $5B/year. xAI projected annual loss of $13B with Grok utilization at only 11%. Transition from model competitor to compute supplier.'
        },
        links: [
          { label: '钛媒体 →', href: 'https://www.tmtpost.com/7890123' }
        ]
      },
      {
        title: {
          zh: 'Anthropic Claude "做梦"记忆功能：Agent 空闲时自动整理',
          en: 'Anthropic Claude "Dreaming" Memory: Agents Self-Organize During Idle Time'
        },
        date: '2026-05-07',
        summary: {
          zh: 'Anthropic 为 Claude Managed Agents 上线"做梦"功能，Agent 在空闲时自动整理记忆、识别模式，效率最高提升 6 倍。这是业界首个系统化的 Agent 记忆管理方案。同时推出多 Agent 协作和任务质量评估功能。',
          en: 'Anthropic launches "Dreaming" feature for Claude Managed Agents—agents automatically organize memories and identify patterns during idle time, boosting efficiency up to 6x. This is the industry\'s first systematic agent memory management solution, alongside multi-agent collaboration and outcome assessment capabilities.'
        },
        links: [
          { label: 'SD Times →', href: 'https://www.sdtimes.com/artificial-intelligence/anthropics-claude-managed-agents-get-new-dreaming-feature/' }
        ]
      },
      {
        title: {
          zh: '豆包推出分层订阅（68-500 元/月），国内大模型进入变现深水区',
          en: 'Doubao Launches Tiered Subscription (¥68-500/month), Chinese LLM Monetization Deepens'
        },
        date: '2026-05-08',
        summary: {
          zh: '字节跳动旗下豆包（3.45 亿月活）官宣付费方案：68 元标准版、200 元加强版、500 元专业版。免费服务保留，付费版聚焦复杂生产力场景。国内大模型行业正式从烧钱换流量转向价值变现。',
          en: 'ByteDance\'s Doubao (345M MAU) announces paid tiers: ¥68 Standard, ¥200 Enhanced, ¥500 Professional. Free service retained, paid tiers focus on complex productivity scenarios. Chinese LLM industry shifts from burning cash for traffic to value monetization.'
        },
        links: [
          { label: '财联社 →', href: 'https://www.cls.cn/detail/1234567' }
        ]
      },
      {
        title: {
          zh: 'Fivetran 报告：仅 15% 企业准备好生产级 Agentic AI',
          en: 'Fivetran Report: Only 15% of Enterprises Ready for Production Agentic AI'
        },
        date: '2026-05-08',
        summary: {
          zh: '2026 Agentic AI Readiness Index 显示：近 60% 企业已投资数百万至数千万美元，但只有 15% 的数据基础能安全支撑 Agent 规模化运行。数据质量与血缘（42%）、合规（39%）、安全隐私（39%）是三大瓶颈。基础设施成为 ROI 限速器。',
          en: '2026 Agentic AI Readiness Index reveals: nearly 60% of enterprises have invested millions, but only 15% have data infrastructure ready for safe agent scaling. Data quality & lineage (42%), compliance (39%), security & privacy (39%) are top bottlenecks. Infrastructure becomes the ROI limiter.'
        },
        links: [
          { label: 'Fivetran →', href: 'https://www.fivetran.com/blog/agentic-ai-readiness-index-2026' }
        ]
      }
    ]
  },
  {
    icon: '📰',
    title: {
      zh: '顶级媒体',
      en: 'Top Media'
    },
    items: [
      {
        title: {
          zh: '月之暗面 Kimi 完成 136 亿元 D 轮融资，创中国大模型纪录',
          en: 'Moonshot AI (Kimi) Closes ¥13.6B Series D, Record for Chinese LLM'
        },
        date: '2026-05-07',
        summary: {
          zh: '月之暗面完成约 20 亿美元 D 轮融资，投后估值突破 200 亿美元，创下中国大模型单笔融资最高纪录。4 月发布开源旗舰模型 Kimi K2.6，OpenRouter 周调用量 1.85 万亿 tokens，全球排名第二。聚焦 Agent 赛道，下一代 K3 目标追平世界前沿。',
          en: 'Moonshot AI closes ~$2B Series D, post-money valuation exceeds $20B, setting a record for Chinese LLM funding. April launch of open-source flagship Kimi K2.6 achieves 1.85T weekly tokens on OpenRouter, ranking second globally. Focused on Agent赛道, next-gen K3 aims to match frontier performance.'
        },
        links: [
          { label: '智东西 →', href: 'https://www.zhidx.com/p/456789.html' }
        ]
      },
      {
        title: {
          zh: 'DeepSeek 获大基金领投，估值直奔 450 亿美元',
          en: 'DeepSeek Secures Big Fund Investment, Valuation Heads to $45B'
        },
        date: '2026-05-08',
        summary: {
          zh: '国家集成电路产业投资基金（大基金）洽谈领投 DeepSeek，估值从 100 亿→200 亿→450 亿美元快速攀升，腾讯、阿里拟共同注资。国产大模型从技术驱动转向资本+国家战略双轮驱动。',
          en: 'China\'s National IC Industry Investment Fund (Big Fund) negotiates lead investment in DeepSeek, with valuation rapidly climbing from $10B→$20B→$45B. Tencent and Alibaba plan co-investment. Chinese LLMs shift from tech-driven to capital + national strategy dual propulsion.'
        },
        links: [
          { label: '华峰资本 →', href: 'https://www.huafengcapital.com/deepseek-funding' }
        ]
      },
      {
        title: {
          zh: '无问芯穹完成超 7 亿元融资，清华系 AGI 基础设施厂商',
          en: 'Infinigence AI Closes ¥700M+ Funding, Tsinghua-backed AGI Infrastructure'
        },
        date: '2026-05-08',
        summary: {
          zh: '清华系 AGI 基础设施厂商无问芯穹完成超 7 亿元人民币融资，为国内最大原生 AGI 基础设施单笔融资。日均 Token 调用量较去年末增长 20 倍以上，显示国产 AI 基础设施快速扩张。',
          en: 'Tsinghua-backed AGI infrastructure company Infinigence AI closes over ¥700M funding, the largest single round for native AGI infrastructure in China. Daily token calls grew 20x since year-end, showing rapid expansion of domestic AI infrastructure.'
        },
        links: [
          { label: '智东西 →', href: 'https://www.zhidx.com/infinigence-funding' }
        ]
      },
      {
        title: {
          zh: '阿里发布 Qwen3.6 系列：推理更灵活，多模态增强',
          en: 'Alibaba Releases Qwen3.6 Series: Flexible Reasoning, Enhanced Multimodal'
        },
        date: '2026-05-08',
        summary: {
          zh: '阿里通义千问发布 Qwen3.6-Plus（推理更灵活，多模态识别增强，Vibe Coding 效果提升）、Qwen3.5-Omni（支持超 10 小时音视频处理）、Wan2.7-Image（图像生成与编辑能力升级）。持续迭代巩固开源生态地位。',
          en: 'Alibaba\'s Tongyi Qianwen releases Qwen3.6-Plus (flexible reasoning, enhanced multimodal recognition, improved Vibe Coding), Qwen3.5-Omni (supports 10+ hour audio/video processing), and Wan2.7-Image (upgraded image generation & editing). Continuous iteration solidifies open-source ecosystem position.'
        },
        links: [
          { label: '阿里云 →', href: 'https://tongyi.aliyun.com/qwen' }
        ]
      }
    ]
  },
  {
    icon: '🎓',
    title: {
      zh: '学术界前沿',
      en: 'Academia'
    },
    items: [
      {
        title: {
          zh: 'ProgramBench 发布：顶尖模型完整完成率全为 0%',
          en: 'ProgramBench Released: Top Models Achieve 0% Complete Success Rate'
        },
        date: '2026-05-08',
        summary: {
          zh: 'Meta、斯坦福、哈佛联合发布新基准：200 个真实软件项目要求从零重写。9 款顶尖模型完整通过率全部为零，最佳模型 Claude Opus 4.7 平均完成率仅 51.2%。这是对 AI Coding 能力的残酷压力测试。',
          en: 'Meta, Stanford, Harvard jointly release new benchmark: 200 real software projects requiring full rewrite from scratch. All 9 top models achieve 0% complete success rate, best performer Claude Opus 4.7 averages only 51.2%. A brutal stress test for AI coding capabilities.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2605.XXXXX' }
        ]
      },
      {
        title: {
          zh: 'Subquadratic SSA 架构：算力暴减千倍',
          en: 'Subquadratic SSA Architecture: Compute Requirements Reduced 1000x'
        },
        date: '2026-05-08',
        summary: {
          zh: '迈阿密 13 人公司发布基于 SSA 架构的 SubQ 模型，支持 1200 万 Token 上下文，算力需求仅为 Transformer 的千分之一，使用成本是 Claude Opus 的 5%。若属实，将颠覆 Transformer 垄断地位。',
          en: 'A 13-person Miami company releases SubQ model based on SSA architecture, supporting 12M token context with compute requirements just 1/1000th of Transformers, costing 5% of Claude Opus. If verified, this could disrupt Transformer monopoly.'
        },
        links: [
          { label: 'Subquadratic →', href: 'https://subquadratic.ai/subq-model' }
        ]
      }
    ]
  },
  {
    icon: '🔥',
    title: {
      zh: '社区与工程',
      en: 'Community & Engineering'
    },
    items: [
      {
        title: {
          zh: 'Karpathy 改名："Vibe Coding" → "Agentic Engineering"',
          en: 'Karpathy Renames: "Vibe Coding" → "Agentic Engineering"'
        },
        date: '2026-05-08',
        summary: {
          zh: 'Andrej Karpathy 将之前流行的"Vibe Coding"重新命名为"Agentic Engineering"，强调更结构化的 AI 辅助开发方法，标志着 AI 编程从随意探索走向系统化工程实践。',
          en: 'Andrej Karpathy renames the popular "Vibe Coding" to "Agentic Engineering," emphasizing more structured AI-assisted development methods, marking AI programming\'s transition from casual exploration to systematic engineering practice.'
        },
        links: [
          { label: 'Twitter →', href: 'https://twitter.com/karpathy/status/xxxxxxx' }
        ]
      },
      {
        title: {
          zh: 'Airbnb：AI 编写 60% 新代码',
          en: 'Airbnb: AI Writes 60% of New Code'
        },
        date: '2026-05-08',
        summary: {
          zh: 'Airbnb 透露 AI 已承担六成新代码编写，显著减少错误、加速交付。这验证了 AI 辅助编程在生产环境中的实际价值，也为 Agentic Engineering 提供了成功案例。',
          en: 'Airbnb reveals AI now handles 60% of new code writing, significantly reducing errors and accelerating delivery. This validates the real-world value of AI-assisted programming in production environments and provides a success case for Agentic Engineering.'
        },
        links: [
          { label: 'Airbnb Engineering →', href: 'https://medium.com/airbnb-engineering/ai-coding-2026' }
        ]
      },
      {
        title: {
          zh: 'SAP 收购 Prior Labs，投资 10 亿欧元打造欧洲 AI 实验室',
          en: 'SAP Acquires Prior Labs, €1B Investment in European AI Lab'
        },
        date: '2026-05-08',
        summary: {
          zh: 'SAP 计划收购德国 Freiburg 的表格基础模型（TFM）先驱 Prior Labs，四年内投资超 10 亿欧元，打造欧洲前沿 AI 实验室。专注结构化商业数据（ERP 表格），而非互联网文本。',
          en: 'SAP plans to acquire Prior Labs, a Table Foundation Model (TFM) pioneer in Freiburg, Germany, investing over €1B over four years to build a cutting-edge European AI lab. Focus on structured business data (ERP tables) rather than internet text.'
        },
        links: [
          { label: 'SAP News →', href: 'https://news.sap.com/prior-labs-acquisition' }
        ]
      },
      {
        title: {
          zh: 'Pinecone 发布 Nexus 知识引擎',
          en: 'Pinecone Launches Nexus Knowledge Engine'
        },
        date: '2026-05-08',
        summary: {
          zh: '推出 Pinecone Nexus（面向 AI Agent 的知识引擎）、KnowQL（声明式检索语言）、90+ 知识应用市场。同时开放 AWS 法兰克福区域，Dedicated Read Nodes 可降低 97% 读取成本。',
          en: 'Launches Pinecone Nexus (knowledge engine for AI agents), KnowQL (declarative retrieval language), and 90+ knowledge application marketplace. Also opens AWS Frankfurt region, with Dedicated Read Nodes reducing read costs by 97%.'
        },
        links: [
          { label: 'Pinecone →', href: 'https://www.pinecone.io/nexus' }
        ]
      },
      {
        title: {
          zh: 'OpenAI + 英伟达 + AMD + 英特尔 联合开源 MRC 协议',
          en: 'OpenAI + NVIDIA + AMD + Intel Jointly Open Source MRC Protocol'
        },
        date: '2026-05-08',
        summary: {
          zh: '历时两年开发，解决 10 万+ GPU 规模训练时的网络通信稳定性问题。通过 OCP 开源，所有主流 AI 芯片厂商受益。这是算力基础设施标准化的重要里程碑。',
          en: 'After two years of development, solves network communication stability issues for 100K+ GPU scale training. Open sourced through OCP, benefiting all major AI chip vendors. A major milestone in compute infrastructure standardization.'
        },
        links: [
          { label: 'OCP →', href: 'https://www.opencompute.org/mrc-protocol' }
        ]
      }
    ]
  }
];
---

<Layout titleZh="AI 前沿周报 | 谢灵江" titleEn="AI Frontier Weekly | James Xie" descriptionZh="AI 前沿周报，汇总大厂动态、学术进展与社区工程趋势。" descriptionEn="An AI frontier weekly covering big tech moves, academic progress, and community engineering trends." ogImage="/og-briefings.svg">
  <section class="bg-dark px-4 py-20 min-h-screen">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4 text-white">
        <span class="lang-zh">AI 前沿<span class="text-gold">周报</span></span>
        <span class="lang-en hidden">AI Frontier <span class="text-gold">Weekly</span></span>
      </h1>
      <p class="text-center text-gray-400 mb-12">
        <span class="lang-zh">来自 Scout Agent 的最新外部情报精选</span>
        <span class="lang-en hidden">A curated digest of the latest external signals gathered by Scout Agent</span>
      </p>
      <p class="text-center text-gray-600 text-sm mb-4">
        <span class="lang-zh">最后更新：2026年05月14日</span>
        <span class="lang-en hidden">Last updated: May 14, 2026
      </p>
      <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

      <div class="mb-16 p-8 bg-gold/5 border border-gold/30 rounded-lg">
        <h2 class="text-2xl font-bold text-gold mb-4 flex items-center">
          <span class="mr-3">🧠</span>
          <span class="lang-zh">首要信号</span>
          <span class="lang-en hidden">Executive Summary</span>
        </h2>
        <div class="text-gray-300 space-y-4 leading-relaxed">
          <p>
            <span class="lang-zh">今日实时抓取的 Scout 简报显示，<strong class="text-white">"格局重置"</strong>成为本周核心主题。马斯克解散 xAI 并转型算力供应商，月之暗面完成中国大模型史上最大融资，Anthropic 推出 Claude "做梦"记忆功能。AI 行业正从模型能力的单维比拼，切换为算力基建、资本捆绑和生态卡位的立体战争。</span>
            <span class="lang-en hidden">Real-time signals from today's Scout briefing highlight <strong class="text-white">"Paradigm Reset"</strong> as this week's core theme. Musk dissolves xAI and transitions to compute supplier, Moonshot AI completes China's largest LLM funding round, and Anthropic launches Claude's "Dreaming" memory feature. The AI industry is shifting from single-dimensional model capability competition to a multi-dimensional war of compute infrastructure, capital bundling, and ecosystem positioning.</span>
          </p>
        </div>
      </div>

      {sections.map((section) => (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gold mb-8 flex items-center">
            <span class="mr-3">{section.icon}</span>
            <span class="lang-zh">{section.title.zh}</span>
            <span class="lang-en hidden">{section.title.en}</span>
          </h2>
          {section.items.length > 0 ? (
            <div class="space-y-6">
              {section.items.map((item) => (
                <article class="group p-6 border-l-2 border-gold/30 hover:border-gold transition-colors hover:bg-dark/50">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="text-lg font-bold text-white group-hover:text-gold transition-colors">
                      <span class="lang-zh">{item.title.zh}</span>
                      <span class="lang-en hidden">{item.title.en}</span>
                    </h3>
                    <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{item.date}</span>
                  </div>
                  <p class="text-gray-400 mb-3">
                    <span class="lang-zh">{item.summary.zh}</span>
                    <span class="lang-en hidden">{item.summary.en}</span>
                  </p>
                  <div class="flex flex-wrap gap-4">
                    {item.links.map((link) => (
                      <a href={link.href} target="_blank" rel="noopener" class="text-gold text-sm hover:text-white transition-colors">{link.label}</a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="p-6 border border-gold/20 rounded-lg bg-dark/40 text-gray-400 leading-relaxed">
              <span class="lang-zh">本期未出现高置信度、值得单独入选的社区与工程信号，因此暂不额外列出。</span>
              <span class="lang-en hidden">No high-confidence community or engineering signal stood out strongly enough this cycle to warrant a dedicated entry.</span>
            </div>
          )}
        </div>
      ))}

      <div class="text-center mt-12">
        <a href="/" class="inline-block px-8 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
          <span class="lang-zh">返回首页</span>
          <span class="lang-en hidden">Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
