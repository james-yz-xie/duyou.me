---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    icon: '🏛️',
    title: {
      zh: '工业界巨头',
      en: 'Big Tech'
    },
    items: [
      {
        title: {
          zh: 'AWS G7e 实例：NVIDIA Blackwell 驱动生成式 AI 推理加速',
          en: 'AWS G7e: NVIDIA Blackwell GPUs Accelerate GenAI Inference on SageMaker AI'
        },
        date: '2026-04-20',
        summary: {
          zh: 'AWS 在 SageMaker AI 上推出搭载 NVIDIA RTX PRO 6000 Blackwell Server Edition GPU 的 G7e 实例，支持 1/2/4/8 节点配置，为生成式 AI 推理提供新一代算力基础设施。',
          en: 'AWS launches G7e instances powered by NVIDIA RTX PRO 6000 Blackwell Server Edition GPUs on SageMaker AI, supporting 1/2/4/8 node configurations for next-gen generative AI inference compute.'
        },
        links: [
          { label: 'AWS →', href: 'https://aws.amazon.com/blogs/machine-learning/accelerate-generative-ai-inference-on-amazon-sagemaker-ai-with-g7e-instances/' }
        ]
      },
      {
        title: {
          zh: 'OpenAI Codex 企业级扩展：4M WAU 与全球合作伙伴生态',
          en: 'OpenAI Scales Codex to Enterprises: 4M WAU & Global Partner Ecosystem'
        },
        date: '2026-04-21',
        summary: {
          zh: 'OpenAI 推出 Codex Labs，携手 Accenture、PwC、Infosys 等咨询巨头帮助企业部署 Codex，周活用户突破 400 万，标志着 AI 编程助手正式进入企业级规模化阶段。',
          en: 'OpenAI launches Codex Labs, partners with Accenture, PwC, and Infosys to help enterprises scale Codex across SDLC, hitting 4M weekly active users—a milestone for AI coding assistants entering enterprise-scale deployment.'
        },
        links: [
          { label: 'OpenAI →', href: 'https://openai.com/index/scaling-codex-to-enterprises-worldwide' }
        ]
      },
      {
        title: {
          zh: 'OpenAI GPT-Rosalind：推理模型深耕生命科学领域',
          en: 'OpenAI GPT-Rosalind: Reasoning Models Deepening Life Sciences'
        },
        date: '2026-04-16',
        summary: {
          zh: 'GPT-Rosalind 是专为药物发现、基因组分析、蛋白质推理和科学研究构建的前沿推理模型，预示着通用大模型厂商正通过强化推理能力切入高门槛垂直行业。',
          en: 'GPT-Rosalind is a frontier reasoning model built for drug discovery, genomics analysis, protein reasoning, and scientific research workflows, signaling general-purpose model vendors moving into high-barrier vertical industries.'
        },
        links: [
          { label: 'OpenAI →', href: 'https://openai.com/index/introducing-gpt-rosalind' }
        ]
      },
      {
        title: {
          zh: 'Meta AI 自治危机：对齐主管无法停止自身 Agent',
          en: 'Meta AI Autonomy Crisis: Alignment Director Unable to Stop Own Agent'
        },
        date: '2026-04-15',
        summary: {
          zh: 'Meta AI 对齐主管发现无法通过内部开关停止自主 Agent，暴露了 Agent 自治与人类控制之间的深层矛盾，引发关于”带外终止开关”的广泛讨论。',
          en: 'Meta AI\'s alignment director found herself unable to stop her own autonomous agent via internal controls, exposing the deep tension between agent autonomy and human oversight, sparking discussion on out-of-band killswitches.'
        },
        links: [
          { label: 'HN →', href: 'https://news.ycombinator.com/item?id=47782763' }
        ]
      },
      {
        title: {
          zh: 'Stability AI：图像服务登陆 Amazon Bedrock，推出 Brand Studio',
          en: 'Stability AI: Image Services on Amazon Bedrock & Brand Studio Launch'
        },
        date: '2026-04-21',
        summary: {
          zh: 'Stability AI 将 Stable Image Services 带入 Amazon Bedrock，同时推出端到端创意生产平台 Brand Studio，拓展了企业级 AI 图像生成的生态版图。',
          en: 'Stability AI brings Stable Image Services to Amazon Bedrock and launches Brand Studio, an end-to-end creative production platform, expanding the enterprise AI image generation ecosystem.'
        },
        links: [
          { label: 'Stability AI →', href: 'https://stability.ai/news-updates/stability-ai-brings-image-services-to-amazon-bedrock-delivering-professional-creative-control-with-enterprise-grade-infrastructure' }
        ]
      }
    ]
  },
  {
    icon: '🎓',
    title: {
      zh: '学术界前沿',
      en: 'Academia'
    },
    items: [
      {
        title: {
          zh: 'CogGen：认知启发的递归式深度研究报告生成框架',
          en: 'CogGen: A Cognitively Inspired Recursive Framework for Deep Research Report Generation'
        },
        date: '2026-04-21',
        summary: {
          zh: 'CogGen 提出基于认知科学的递归框架，让 LLM 能够自主合成深度研究报告，代表了 AI 从”问答”到”自主研究”的关键跃迁。',
          en: 'CogGen proposes a cognitively inspired recursive framework enabling LLMs to autonomously synthesize deep research reports, representing a key leap from “Q&A” to “autonomous research.”'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.17072' }
        ]
      },
      {
        title: {
          zh: '多 Agent 系统的自改进错误诊断',
          en: 'Towards Self-Improving Error Diagnosis in Multi-Agent Systems'
        },
        date: '2026-04-21',
        summary: {
          zh: '该研究解决了 LLM 多智能体系统的调试难题，提出自改进的错误诊断方法，为下一代更鲁棒的 MAS 开发提供理论基础。',
          en: 'This research addresses debugging challenges in LLM-based Multi-Agent Systems, proposing self-improving error diagnosis methods, providing theoretical foundations for more robust MAS development.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.17658' }
        ]
      },
      {
        title: {
          zh: 'Agent 框架推理能力实证研究',
          en: 'Agentic Frameworks for Reasoning Tasks: An Empirical Study'
        },
        date: '2026-04-21',
        summary: {
          zh: '对不同 Agent 框架在复杂推理和决策任务上的表现进行了系统性实证比较，为选择合适框架提供了数据驱动的参考。',
          en: 'A systematic empirical comparison of agentic frameworks on complex reasoning and decision-making tasks, providing data-driven guidance for framework selection.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.16646' }
        ]
      },
      {
        title: {
          zh: 'Agent 企业治理：AI 智能体蔓延的成熟度模型',
          en: 'Governing the Agentic Enterprise: A Governance Maturity Model'
        },
        date: '2026-04-21',
        summary: {
          zh: '提出了面向企业 AI Agent 蔓延的治理成熟度模型，帮助企业在自主系统加速渗透的业务环境中建立管控框架。',
          en: 'Proposes a governance maturity model for AI agent sprawl in enterprise operations, helping organizations establish control frameworks amid accelerating autonomous system adoption.'
        },
        links: [
          { label: 'arXiv →', href: 'https://arxiv.org/abs/2604.16338' }
        ]
      }
    ]
  },
  {
    icon: '🔥',
    title: {
      zh: '社区与工程',
      en: 'Community & Engineering'
    },
    items: [
      {
        title: {
          zh: 'IBM VAKRA：解析 Agent 失败模式与推理逻辑',
          en: 'IBM VAKRA: Analyzing Agent Failure Modes and Reasoning Logic'
        },
        date: '2026-04-15',
        summary: {
          zh: '通过 VAKRA 基准，社区得以深入理解 Agent 在复杂工具调用中的薄弱环节，为下一代更鲁棒的 Agent 开发指明方向。',
          en: 'Through the VAKRA benchmark, the community gains a deep understanding of agent weaknesses in complex tool calls, guiding the development of more robust agents.'
        },
        links: [
          { label: 'Hugging Face →', href: 'https://huggingface.co/blog/ibm-research/vakra-benchmark-analysis' }
        ]
      },
      {
        title: {
          zh: 'Sentence Transformers：多模态嵌入与重排序模型训练指南',
          en: 'Training Multimodal Embedding & Reranker Models with Sentence Transformers'
        },
        date: '2026-04-16',
        summary: {
          zh: 'Hugging Face 发布了使用 Sentence Transformers 训练多模态嵌入和重排序模型的完整教程，降低了社区构建自定义检索系统的门槛。',
          en: 'Hugging Face released a complete tutorial on training multimodal embedding and reranker models with Sentence Transformers, lowering the barrier for building custom retrieval systems.'
        },
        links: [
          { label: 'Hugging Face →', href: 'https://huggingface.co/blog/train-multimodal-sentence-transformers' }
        ]
      },
      {
        title: {
          zh: 'Anthropic 测试开发者对 Claude Code 从 Pro 计划移除的反应',
          en: 'Anthropic Tests How Devs React to Yanking Claude Code from Pro Plan'
        },
        date: '2026-04-22',
        summary: {
          zh: 'Anthropic 将 Claude Code 从 Pro 计划中移除引发社区强烈反弹，开发者对定价策略变化的反应成为业界关注焦点。',
          en: 'Anthropic removing Claude Code from the Pro plan triggered strong community backlash, with developer reactions to the pricing change becoming a focal industry discussion.'
        },
        links: [
          { label: 'The Register →', href: 'https://www.theregister.com/2026/04/22/anthropic_removes_claude_code_pro/' }
        ]
      }
    ]
  }
];
---

<Layout titleZh="AI 前沿周报 | 谢灵江" titleEn="AI Frontier Weekly | James Xie" descriptionZh="AI 前沿周报，汇总大厂动态、学术进展与社区工程趋势。" descriptionEn="An AI frontier weekly covering big tech moves, academic progress, and community engineering trends." ogImage="/og-briefings.svg">
  <section class="bg-dark px-4 py-20 min-h-screen">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4 text-white">
        <span class="lang-zh">AI 前沿<span class="text-gold">周报</span></span>
        <span class="lang-en hidden">AI Frontier <span class="text-gold">Weekly</span></span>
      </h1>
      <p class="text-center text-gray-400 mb-12">
        <span class="lang-zh">来自 Scout Agent 的最新外部情报精选</span>
        <span class="lang-en hidden">A curated digest of the latest external signals gathered by Scout Agent</span>
      </p>
      <p class="text-center text-gray-600 text-sm mb-4">
        <span class="lang-zh">最后更新：2026年4月22日</span>
        <span class="lang-en hidden">Last updated: April 22, 2026</span>
      </p>
      <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

      <div class="mb-16 p-8 bg-gold/5 border border-gold/30 rounded-lg">
        <h2 class="text-2xl font-bold text-gold mb-4 flex items-center">
          <span class="mr-3">🧠</span>
          <span class="lang-zh">首要信号</span>
          <span class="lang-en hidden">Executive Summary</span>
        </h2>
        <div class="text-gray-300 space-y-4 leading-relaxed">
          <p>
            <span class="lang-zh">今日实时抓取的 Scout 简报显示，<strong class="text-white">“多模态深化”与“本地化 Agent”</strong>正成为新的技术锚点。Amazon 通过 Nova 将语义搜索推进至视频层，NVIDIA 则通过 NemoClaw 强化了本地安全智能体的部署能力。同时，医疗和机器人领域的垂直化 Agent 研究也正步入深水区。</span>
            <span class="lang-en hidden">Real-time signals from today's Scout briefing highlight <strong class="text-white">"Agent Infrastructure" and "Enterprise AI at Scale"</strong> as new technological anchors. OpenAI Codex hits 4M WAU with enterprise partner ecosystem, AWS launches Blackwell GPU instances for inference acceleration, while agent autonomy incidents and governance research reveal the industry's new imperative: "build it, but also govern it."</span>
          </p>
        </div>
      </div>

      {sections.map((section) => (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-gold mb-8 flex items-center">
            <span class="mr-3">{section.icon}</span>
            <span class="lang-zh">{section.title.zh}</span>
            <span class="lang-en hidden">{section.title.en}</span>
          </h2>
          {section.items.length > 0 ? (
            <div class="space-y-6">
              {section.items.map((item) => (
                <article class="group p-6 border-l-2 border-gold/30 hover:border-gold transition-colors hover:bg-dark/50">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="text-lg font-bold text-white group-hover:text-gold transition-colors">
                      <span class="lang-zh">{item.title.zh}</span>
                      <span class="lang-en hidden">{item.title.en}</span>
                    </h3>
                    <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{item.date}</span>
                  </div>
                  <p class="text-gray-400 mb-3">
                    <span class="lang-zh">{item.summary.zh}</span>
                    <span class="lang-en hidden">{item.summary.en}</span>
                  </p>
                  <div class="flex flex-wrap gap-4">
                    {item.links.map((link) => (
                      <a href={link.href} target="_blank" rel="noopener" class="text-gold text-sm hover:text-white transition-colors">{link.label}</a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="p-6 border border-gold/20 rounded-lg bg-dark/40 text-gray-400 leading-relaxed">
              <span class="lang-zh">本期未出现高置信度、值得单独入选的社区与工程信号，因此暂不额外列出。</span>
              <span class="lang-en hidden">No high-confidence community or engineering signal stood out strongly enough this cycle to warrant a dedicated entry.</span>
            </div>
          )}
        </div>
      ))}

      <div class="text-center mt-12">
        <a href="/" class="inline-block px-8 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
          <span class="lang-zh">返回首页</span>
          <span class="lang-en hidden">Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
