---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout 
  titleZh={post.data.title.zh} 
  titleEn={post.data.title.en} 
  descriptionZh={post.data.description.zh} 
  descriptionEn={post.data.description.en}
  ogImage={post.data.ogImage || '/og-home.svg'}
>
  <section class="bg-dark px-4 py-20 min-h-screen">
    <div class="max-w-5xl mx-auto">
      <div class="flex justify-between items-center mb-12">
        <a href="/blog/" class="inline-flex items-center text-gold hover:text-white transition-colors text-sm">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span class="lang-zh">返回博客列表</span>
          <span class="lang-en hidden">Back to blog</span>
        </a>
        <span class="text-sm text-gray-500 font-mono">
          {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
      </div>

      <header class="mb-12">
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-8 tracking-tight leading-tight">
          <span class="lang-zh">{post.data.title.zh}</span>
          <span class="lang-en hidden">{post.data.title.en}</span>
        </h1>

        <div class="flex flex-wrap items-center gap-4 mb-8">
          <div class="flex items-center space-x-2">
            <span class="px-3 py-1 text-xs font-semibold bg-gold/10 text-gold rounded-md border border-gold/20 tracking-wider uppercase">{post.data.category}</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {post.data.tags?.map((tag) => (
              <span class="px-3 py-1 text-xs bg-white/5 text-gray-400 rounded-md border border-white/10 italic">#{tag}</span>
            ))}
          </div>
        </div>
        <div class="h-px bg-gradient-to-r from-gold/50 to-transparent w-full"></div>
      </header>

      <article class="prose-markdown">
        <Content />
      </article>

      <div class="mt-12 pt-8 border-t border-white/10">
        <div class="flex justify-between">
          <a href="/blog/" class="inline-block px-6 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
            <span class="lang-zh">返回博客列表</span>
            <span class="lang-en hidden">Back to blog</span>
          </a>
          <a href="/" class="inline-block px-6 py-3 border-2 border-white/20 text-white hover:bg-white/10 transition-all font-semibold">
            <span class="lang-zh">返回首页</span>
            <span class="lang-en hidden">Back to Home</span>
          </a>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script is:inline>
  const runMermaid = async () => {
    console.log('[Mermaid] Discovery started...');
    
    // 1. 扫描所有的 pre 和 code
    const allPres = document.querySelectorAll('pre');
    console.log(`[Mermaid] Total pre tags found: ${allPres.length}`);

    const mermaidTargets = [];
    
    allPres.forEach((pre, i) => {
        const text = pre.textContent.trim();
        const className = pre.className || "";
        const codeTag = pre.querySelector('code');
        const codeClass = codeTag ? codeTag.className : "";
        
        console.log(`[Mermaid] Pre[${i}] classes: "${className}", Code classes: "${codeClass}"`);

        // 如果类名里有 mermaid，或者内容以 graph/sequenceDiagram/etc 开头
        if (
            className.includes('mermaid') || 
            codeClass.includes('mermaid') ||
            text.startsWith('graph ') || 
            text.startsWith('sequenceDiagram') ||
            text.startsWith('gantt') ||
            text.startsWith('classDiagram') ||
            text.startsWith('stateDiagram') ||
            text.startsWith('pie') ||
            text.startsWith('flowchart')
        ) {
            console.log(`[Mermaid] Found candidate at Pre[${i}]`);
            mermaidTargets.push(pre);
        }
    });

    if (mermaidTargets.length === 0) {
        console.log('[Mermaid] No mermaid blocks identified');
        return;
    }

    if (typeof mermaid === 'undefined') {
        console.error('[Mermaid] Library not loaded');
        return;
    }

    mermaid.initialize({
      startOnLoad: false,
      theme: 'dark',
      themeVariables: {
        primaryColor: '#D4AF37',
        primaryTextColor: '#fff',
        lineColor: '#D4AF37',
        mainBkg: '#1a1a1a',
      }
    });

    for (const target of mermaidTargets) {
      const content = target.textContent.trim();
      const container = document.createElement('div');
      container.className = 'mermaid';
      container.style.cssText = 'display: flex; justify-content: center; padding: 2rem; background: rgba(255,255,255,0.05); border-radius: 0.75rem; margin-bottom: 2rem;';
      container.textContent = content;
      
      target.parentNode.replaceChild(container, target);
    }
    
    await mermaid.run();
    console.log('[Mermaid] Render successful');
  };

  // Run with various triggers
  setTimeout(runMermaid, 500);
  document.addEventListener('astro:page-load', runMermaid);
  window.addEventListener('load', runMermaid);
</script>
