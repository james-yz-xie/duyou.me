---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

const pageData = {
  zh: {
    title: 'YouTube 字幕提取器',
    description: '输入 YouTube 视频链接，自动提取字幕内容',
    inputLabel: 'YouTube 视频链接',
    inputPlaceholder: '例如: https://www.youtube.com/watch?v=xRh2sVcNXQ8',
    extractButton: '提取字幕',
    extracting: '正在提取...',
    noSubtitles: '未找到字幕',
    downloadSrt: '下载 SRT 格式',
    copyText: '复制文本',
    copied: '已复制',
    errorInvalidUrl: '请输入有效的 YouTube 视频链接',
    errorNoVideoId: '无法从链接中提取视频 ID',
    errorFetchFailed: '提取失败，请检查网络连接或视频是否存在',
    successMessage: '成功提取字幕',
    backToAgents: '返回 Agent 导航'
  },
  en: {
    title: 'YouTube Subtitle Extractor',
    description: 'Enter a YouTube video URL to automatically extract subtitles',
    inputLabel: 'YouTube Video URL',
    inputPlaceholder: 'e.g., https://www.youtube.com/watch?v=xRh2sVcNXQ8',
    extractButton: 'Extract Subtitles',
    extracting: 'Extracting...',
    noSubtitles: 'No subtitles found',
    downloadSrt: 'Download as SRT',
    copyText: 'Copy Text',
    copied: 'Copied',
    errorInvalidUrl: 'Please enter a valid YouTube video URL',
    errorNoVideoId: 'Unable to extract video ID from URL',
    errorFetchFailed: 'Extraction failed. Please check your connection or if the video exists',
    successMessage: 'Successfully extracted subtitles',
    backToAgents: 'Back to Agents'
  }
};
---

<Layout 
  titleZh={pageData.zh.title} 
  titleEn={pageData.en.title}
  descriptionZh={pageData.zh.description}
  descriptionEn={pageData.en.description}
>
  <div class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900 py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      {/* Back Button */}
      <div class="mb-8">
        <a href="/agents" class="inline-flex items-center gap-2 text-gold hover:text-gold/80 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <span class="lang-zh">{pageData.zh.backToAgents}</span>
          <span class="lang-en hidden">{pageData.en.backToAgents}</span>
        </a>
      </div>

      {/* Header */}
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-yellow-400 to-orange-500 bg-clip-text text-transparent">
          <span class="lang-zh">{pageData.zh.title}</span>
          <span class="lang-en hidden">{pageData.en.title}</span>
        </h1>
        <p class="text-gray-400 text-lg">
          <span class="lang-zh">{pageData.zh.description}</span>
          <span class="lang-en hidden">{pageData.en.description}</span>
        </p>
      </div>

      {/* Input Section */}
      <div class="bg-gray-800/50 backdrop-blur-sm rounded-2xl p-6 md:p-8 shadow-xl border border-gray-700/50 mb-8">
        <div class="space-y-4">
          <label for="video-url" class="block text-sm font-medium text-gray-300">
            <span class="lang-zh">{pageData.zh.inputLabel}</span>
            <span class="lang-en hidden">{pageData.en.inputLabel}</span>
          </label>
          
          <div class="flex flex-col sm:flex-row gap-3">
            <input
              type="url"
              id="video-url"
              class="flex-1 px-4 py-3 bg-gray-900/50 border border-gray-600 rounded-lg focus:ring-2 focus:ring-yellow-500 focus:border-transparent outline-none text-white placeholder-gray-500 transition-all"
              placeholder={pageData.zh.inputPlaceholder}
            />
            <button
              id="extract-btn"
              class="px-6 py-3 bg-gradient-to-r from-yellow-500 to-orange-500 hover:from-yellow-600 hover:to-orange-600 text-white font-semibold rounded-lg transition-all duration-300 transform hover:scale-105 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 whitespace-nowrap"
            >
              <span class="lang-zh">{pageData.zh.extractButton}</span>
              <span class="lang-en hidden">{pageData.en.extractButton}</span>
            </button>
          </div>

          {/* Error Message */}
          <div id="error-message" class="hidden text-red-400 text-sm mt-2"></div>
        </div>
      </div>

      {/* Loading Indicator */}
      <div id="loading" class="hidden text-center py-8">
        <div class="inline-block animate-spin rounded-full h-12 w-12 border-4 border-yellow-500 border-t-transparent"></div>
        <p class="mt-4 text-gray-400">
          <span class="lang-zh">{pageData.zh.extracting}</span>
          <span class="lang-en hidden">{pageData.en.extracting}</span>
        </p>
      </div>

      {/* Results Section */}
      <div id="results" class="hidden space-y-4">
        {/* Success Message */}
        <div class="bg-green-900/30 border border-green-700/50 rounded-lg p-4">
          <p class="text-green-400 text-center">
            <span class="lang-zh">{pageData.zh.successMessage}</span>
            <span class="lang-en hidden">{pageData.en.successMessage}</span>
          </p>
        </div>

        {/* Action Buttons */}
        <div class="flex flex-wrap gap-3 justify-center">
          <button
            id="download-srt"
            class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors flex items-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            <span class="lang-zh">{pageData.zh.downloadSrt}</span>
            <span class="lang-en hidden">{pageData.en.downloadSrt}</span>
          </button>
          
          <button
            id="copy-text"
            class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition-colors flex items-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <span class="lang-zh">{pageData.zh.copyText}</span>
            <span class="lang-en hidden">{pageData.en.copyText}</span>
          </button>
        </div>

        {/* Subtitle Content */}
        <div class="bg-gray-800/50 backdrop-blur-sm rounded-2xl p-6 shadow-xl border border-gray-700/50">
          <pre id="subtitle-content" class="whitespace-pre-wrap text-gray-300 text-sm leading-relaxed max-h-96 overflow-y-auto custom-scrollbar"></pre>
        </div>
      </div>
    </div>
  </div>

  <Footer />

  <style>
    .custom-scrollbar::-webkit-scrollbar {
      width: 8px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(255, 215, 0, 0.3);
      border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: rgba(255, 215, 0, 0.5);
    }
  </style>

  <script>
    // Extract video ID from YouTube URL
    function extractVideoId(url: string): string | null {
      const patterns = [
        /(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\n?#]+)/,
        /youtube\.com\/embed\/([^&\n?#]+)/,
        /youtube\.com\/v\/([^&\n?#]+)/,
      ];
      
      for (const pattern of patterns) {
        const match = url.match(pattern);
        if (match) return match[1];
      }
      return null;
    }

    // Convert subtitles to SRT format
    function convertToSRT(subtitles: any[]): string {
      let srt = '';
      subtitles.forEach((sub: any, index: number) => {
        const startTime = formatTime(sub.start);
        const endTime = formatTime(sub.start + sub.duration);
        srt += `${index + 1}\n${startTime} --> ${endTime}\n${sub.text}\n\n`;
      });
      return srt.trim();
    }

    // Format time for SRT (HH:MM:SS,mmm)
    function formatTime(seconds: number): string {
      const hours = Math.floor(seconds / 3600);
      const minutes = Math.floor((seconds % 3600) / 60);
      const secs = Math.floor(seconds % 60);
      const ms = Math.floor((seconds % 1) * 1000);
      
      return `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(secs).padStart(2, '0')},${String(ms).padStart(3, '0')}`;
    }

    // Main extraction function
    async function extractSubtitles() {
      const urlInput = document.getElementById('video-url') as HTMLInputElement | null;
      const extractBtn = document.getElementById('extract-btn') as HTMLButtonElement | null;
      const loadingDiv = document.getElementById('loading');
      const resultsDiv = document.getElementById('results');
      const errorDiv = document.getElementById('error-message');
      const subtitleContent = document.getElementById('subtitle-content');
      
      if (!urlInput || !extractBtn) return;
      
      const url = urlInput.value.trim();
      
      // Reset UI
      if (errorDiv) errorDiv.classList.add('hidden');
      if (resultsDiv) resultsDiv.classList.add('hidden');
      
      // Validate URL
      if (!url || !url.includes('youtube.com') && !url.includes('youtu.be')) {
        showError(getLangText('errorInvalidUrl'));
        return;
      }
      
      const videoId = extractVideoId(url);
      if (!videoId) {
        showError(getLangText('errorNoVideoId'));
        return;
      }
      
      // Show loading
      if (loadingDiv) loadingDiv.classList.remove('hidden');
      extractBtn.disabled = true;
      extractBtn.textContent = getLangText('extracting');
      
      try {
        // Use YouTube's timedtext API to get subtitles
        const response = await fetch(`https://www.youtube.com/api/timedtext?v=${videoId}&fmt=json3`);
        
        if (!response.ok) {
          throw new Error('Failed to fetch subtitles');
        }
        
        const data = await response.json();
        
        if (!data.events || data.events.length === 0) {
          showError(getLangText('noSubtitles'));
          return;
        }
        
        // Process subtitles
        const subtitles = data.events
          .filter((event: any) => event.segs)
          .map((event: any) => ({
            start: event.tStartMs / 1000,
            duration: (event.dDurationMs || 0) / 1000,
            text: event.segs.map((seg: any) => seg.utf8 || '').join('').trim()
          }))
          .filter((sub: any) => sub.text.length > 0);
        
        if (subtitles.length === 0) {
          showError(getLangText('noSubtitles'));
          return;
        }
        
        // Display results
        const plainText = subtitles.map((sub: any) => sub.text).join('\n\n');
        const srtContent = convertToSRT(subtitles);
        
        if (subtitleContent) {
          subtitleContent.textContent = plainText;
        }
        
        // Store for download/copy
        (window as any).currentSubtitles = {
          plain: plainText,
          srt: srtContent,
          videoId: videoId
        };
        
        if (resultsDiv) {
          resultsDiv.classList.remove('hidden');
        }
        
      } catch (error) {
        console.error('Error:', error);
        showError(getLangText('errorFetchFailed'));
      } finally {
        loadingDiv.classList.add('hidden');
        extractBtn.disabled = false;
        updateButtonText();
      }
    }

    // Show error message
    function showError(message: string) {
      const errorDiv = document.getElementById('error-message');
      if (errorDiv) {
        errorDiv.textContent = message;
        errorDiv.classList.remove('hidden');
      }
    }

    // Get language-specific text
    function getLangText(key: string): string {
      const lang = document.documentElement.lang as 'zh' | 'en';
      const texts: Record<string, Record<string, string>> = {
        zh: {
          errorInvalidUrl: '请输入有效的 YouTube 视频链接',
          errorNoVideoId: '无法从链接中提取视频 ID',
          errorFetchFailed: '提取失败，请检查网络连接或视频是否存在',
          noSubtitles: '未找到字幕',
          extracting: '正在提取...'
        },
        en: {
          errorInvalidUrl: 'Please enter a valid YouTube video URL',
          errorNoVideoId: 'Unable to extract video ID from URL',
          errorFetchFailed: 'Extraction failed. Please check your connection or if the video exists',
          noSubtitles: 'No subtitles found',
          extracting: 'Extracting...'
        }
      };
      return texts[lang]?.[key] || texts.zh[key];
    }

    // Update button text based on language
    function updateButtonText() {
      const extractBtn = document.getElementById('extract-btn') as HTMLButtonElement | null;
      if (!extractBtn) return;
      const lang = document.documentElement.lang;
      extractBtn.innerHTML = lang === 'zh' 
        ? '<span class="lang-zh">提取字幕</span><span class="lang-en hidden">Extract Subtitles</span>'
        : '<span class="lang-zh hidden">提取字幕</span><span class="lang-en">Extract Subtitles</span>';
    }

    // Event listeners
    document.addEventListener('DOMContentLoaded', () => {
      const extractBtn = document.getElementById('extract-btn');
      const urlInput = document.getElementById('video-url');
      
      if (!extractBtn || !urlInput) return;
      
      extractBtn.addEventListener('click', extractSubtitles);
      
      urlInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          extractSubtitles();
        }
      });
      
      // Download SRT
      const downloadBtn = document.getElementById('download-srt');
      if (downloadBtn) {
        downloadBtn.addEventListener('click', () => {
          const subtitles = (window as any).currentSubtitles;
          if (subtitles) {
            const blob = new Blob([subtitles.srt], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `subtitles_${subtitles.videoId}.srt`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
          }
        });
      }
      
      // Copy text
      const copyBtn = document.getElementById('copy-text');
      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          const subtitles = (window as any).currentSubtitles;
          if (subtitles) {
            try {
              await navigator.clipboard.writeText(subtitles.plain);
              const originalHTML = copyBtn.innerHTML;
              const lang = document.documentElement.lang;
              copyBtn.innerHTML = lang === 'zh'
                ? '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span class="lang-zh">已复制</span><span class="lang-en hidden">Copied</span>'
                : '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span class="lang-zh hidden">已复制</span><span class="lang-en">Copied</span>';
              
              setTimeout(() => {
                copyBtn.innerHTML = originalHTML;
              }, 2000);
            } catch (err) {
              console.error('Failed to copy:', err);
            }
          }
        });
      }
    });
  </script>
</Layout>
