---

<Layout titleZh="AI Agent CLI 导航站" titleEn="AI Agent CLI Hub" descriptionZh="国内外主流 AI Agent CLI 工具导航站，快速访问、安装命令与横向对比" descriptionEn="Curated directory of AI Agent CLI tools with install commands and comparison" ogImage="/og-agents.svg">
  <section class="min-h-screen bg-dark py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-white">
          AI Agent <span class="text-gold">CLI</span> 导航站
        </h1>
        <p class="text-lg text-gray-400 mb-2">国内外主流 AI Agent 命令行工具精选</p>
        <p class="text-sm text-gold">2026 年 4 月更新</p>
      </div>

      <!-- 标签切换 -->
      <div class="flex justify-center gap-4 mb-12 flex-wrap">
        <button class="tab-btn px-6 py-2 bg-gold text-dark font-semibold rounded-full" data-tab="international">
          国外工具
        </button>
        <button class="tab-btn px-6 py-2 border-2 border-gray-600 text-gray-400 hover:border-gold hover:text-gold font-semibold rounded-full" data-tab="chinese">
          中国工具
        </button>
        <button class="tab-btn px-6 py-2 border-2 border-gray-600 text-gray-400 hover:border-gold hover:text-gold font-semibold rounded-full" data-tab="comparison">
          对比表格
        </button>
      </div>

      <!-- 国外工具 -->
      <div id="international" class="tool-section">
        <div class="grid gap-4">
          {internationalTools.map((tool) => (
            <a href={tool.url} target="_blank" rel="noopener noreferrer" class="block bg-gray-900 border border-gray-800 hover:border-gold rounded-lg p-6 transition-all group">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <h3 class="text-xl font-bold text-white group-hover:text-gold">{tool.name}</h3>
                    {tool.stars !== '-' && (
                      <span class="text-sm text-gray-500">★ {tool.stars}</span>
                    )}
                    <span class="text-xs px-2 py-1 bg-gray-800 text-gray-400 rounded">{tool.category}</span>
                    {tool.reasoning && <span class="text-[10px] px-2 py-0.5 bg-gold/10 text-gold border border-gold/20 rounded">REASONING</span>}
                  </div>
                  <p class="text-gray-400 mb-2">{tool.description}</p>
                  <div class="copy-cmd inline-flex items-center gap-2 text-sm text-gold-dark bg-gray-800 px-2 py-1 rounded cursor-pointer hover:bg-gray-700 transition-colors" data-cmd={tool.install}>
                    <code>{tool.install}</code>
                    <svg class="copy-icon w-3.5 h-3.5 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                    <svg class="check-icon w-3.5 h-3.5 text-emerald-400 shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </div>
                </div>
                <div class="text-right md:w-40">
                  <p class="text-sm text-gray-500 mb-1">价格</p>
                  <p class="text-white font-medium">{tool.price}</p>
                  {tool.swebench !== '-' && (
                    <>
                      <p class="text-sm text-gray-500 mb-1 mt-2">SWE-bench</p>
                      <p class="text-gold font-medium">{tool.swebench}</p>
                    </>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- 中国工具 -->
      <div id="chinese" class="tool-section hidden">
        <div class="grid gap-4">
          {chineseTools.map((tool) => (
            <a href={tool.url} target="_blank" rel="noopener noreferrer" class="block bg-gray-900 border border-gray-800 hover:border-gold rounded-lg p-6 transition-all group">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <h3 class="text-xl font-bold text-white group-hover:text-gold">{tool.nameZh}</h3>
                    {tool.stars !== '-' && (
                      <span class="text-sm text-gray-500">★ {tool.stars}</span>
                    )}
                    <span class="text-xs px-2 py-1 bg-gray-800 text-gray-400 rounded">{tool.category}</span>
                    {tool.reasoning && <span class="text-[10px] px-2 py-0.5 bg-gold/10 text-gold border border-gold/20 rounded">REASONING</span>}
                  </div>
                  <p class="text-gray-400 mb-2">{tool.description}</p>
                  <div class="copy-cmd inline-flex items-center gap-2 text-sm text-gold-dark bg-gray-800 px-2 py-1 rounded cursor-pointer hover:bg-gray-700 transition-colors" data-cmd={tool.install}>
                    <code>{tool.install}</code>
                    <svg class="copy-icon w-3.5 h-3.5 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                    <svg class="check-icon w-3.5 h-3.5 text-emerald-400 shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </div>
                </div>
                <div class="text-right md:w-40">
                  <p class="text-sm text-gray-500 mb-1">价格</p>
                  <p class="text-white font-medium">{tool.price}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- 对比表格 -->
      <div id="comparison" class="tool-section hidden">
        <div class="mt-16">
          <h2 class="text-2xl font-bold text-white text-center mb-8">核心对比</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="border-b border-gray-800">
                  <th class="py-3 px-4 text-gray-400 font-medium">工具</th>
                  <th class="py-3 px-4 text-gray-400 font-medium">类型</th>
                  <th class="py-3 px-4 text-gray-400 font-medium text-center">开源</th>
                  <th class="py-3 px-4 text-gray-400 font-medium text-center">长思考支持</th>
                  <th class="py-3 px-4 text-gray-400 font-medium">价格</th>
                  <th class="py-3 px-4 text-gray-400 font-medium">地区</th>
                </tr>
              </thead>
              <tbody>
                {allTools.map((tool) => (
                  <tr class="border-b border-gray-800 hover:bg-white/5 transition-colors">
                    <td class="py-3 px-4 text-white font-medium">{tool.nameZh || tool.name}</td>
                    <td class="py-3 px-4 text-gray-400 text-sm">{tool.type}</td>
                    <td class="py-3 px-4 text-center">
                      {tool.isOpenSource ? <span class="text-gold">✓</span> : <span class="text-gray-600">❌</span>}
                    </td>
                    <td class="py-3 px-4 text-center">
                      {tool.reasoning ? <span class="text-gold text-xs bg-gold/10 px-2 py-0.5 rounded">Supported</span> : <span class="text-gray-600">❌</span>}
                    </td>
                    <td class="py-3 px-4 text-white text-sm">{tool.price}</td>
                    <td class="py-3 px-4 text-gray-400 text-sm">{tool.region}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- 快速选择建议 -->
      <div class="mt-20">
        <h2 class="text-2xl font-bold text-white text-center mb-8">快速选择</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
            <h3 class="text-lg font-bold text-gold mb-3">🎯 免费开源</h3>
            <ul class="text-gray-400 space-y-2 text-sm">
              <li>• OpenCode - 国际开源首选</li>
              <li>• CountBot - 国产开源框架</li>
              <li>• Aider - 配对编程金标准</li>
            </ul>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
            <h3 class="text-lg font-bold text-gold mb-3">🧠 推理能力 (New)</h3>
            <ul class="text-gray-400 space-y-2 text-sm">
              <li>• Claude Code - 配合 Proxy 支持 Qwen 3</li>
              <li>• Gemini CLI - 极致 Context 思考</li>
              <li>• fuxi-cli - 国产长推理优化</li>
            </ul>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
            <h3 class="text-lg font-bold text-gold mb-3">🔌 插件生态</h3>
            <ul class="text-gray-400 space-y-2 text-sm">
              <li>• Goose - 100+ MCP 服务器</li>
              <li>• OpenMozi - 国产生态集成</li>
              <li>• Cline - VS Code 深度集成</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Footer />

  <script is:inline>
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;

        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('bg-gold', 'text-dark');
          b.classList.add('border-2', 'border-gray-600', 'text-gray-400');
        });
        btn.classList.add('bg-gold', 'text-dark');
        btn.classList.remove('border-2', 'border-gray-600', 'text-gray-400');

        document.querySelectorAll('.tool-section').forEach(s => s.classList.add('hidden'));
        document.getElementById(tab).classList.remove('hidden');
      });
    });

    // Copy install command
    document.querySelectorAll('.copy-cmd').forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const cmd = el.dataset.cmd;
        navigator.clipboard.writeText(cmd).then(() => {
          const copyIcon = el.querySelector('.copy-icon');
          const checkIcon = el.querySelector('.check-icon');
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
          }, 1500);
        });
      });
    });
  </script>
</Layout>
