---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const recommendations = [
  {
    zh: '深耕特定领域 AI Agent 技能',
    en: 'Go deep on domain-specific AI agent skills',
    detailZh: '与其构建通用型 Agent，不如围绕具体行业或工作流打磨高价值、可复用的 Agent 技能。',
    detailEn: 'Instead of building a generic agent, focus on reusable high-value skills for a specific industry or workflow.'
  },
  {
    zh: '探索“人格化”AI Agent',
    en: 'Explore persona-driven AI agents',
    detailZh: '把记忆、个性和行为模式组合起来，往往比单纯堆模型参数更能提升体验与留存。',
    detailEn: 'Combining memory, personality, and behavior often improves user experience and retention more than scaling raw model power.'
  },
  {
    zh: '关注 Agent 框架与工具链',
    en: 'Track agent frameworks and tooling',
    detailZh: '利用 Hermes 等开源框架与相关监控管理工具，可以更快搭建可运行、可观测的 Agent 系统。',
    detailEn: 'Open frameworks like Hermes and their surrounding observability tools can accelerate delivery of robust agent systems.'
  },
  {
    zh: '拥抱多模态与模型微调',
    en: 'Adopt multimodality and fine-tuning',
    detailZh: '掌握多模态模型和本地微调能力，将显著增强 Agent 的感知和交互上限。',
    detailEn: 'Mastering multimodal models and local fine-tuning expands the perception and interaction ceiling of your agents.'
  }
];

const sections = [
  {
    icon: '🤖',
    title: {
      zh: 'AI Agent 核心与生态',
      en: 'AI Agent Core & Ecosystem'
    },
    items: [
      {
        repo: 'xixu-me/awesome-persona-distill-skills',
        stars: '3295',
        summary: {
          zh: '一个精选的 Agent 技能列表，聚焦人格、关系与方法论视角，对于构建具备情境感知和角色能力的 AI Agent 很有价值。',
          en: 'A curated collection of agent skills centered on persona, relationships, and operating methodology for building context-aware AI agents.'
        },
        href: 'https://github.com/xixu-me/awesome-persona-distill-skills'
      },
      {
        repo: 'alchaincyf/hermes-agent-orange-book',
        stars: '1994',
        summary: {
          zh: 'Nous Research 开源 Agent 框架 Hermes 的实战指南，从入门到深度开发都有覆盖。',
          en: 'A practical guide to the open-source Hermes agent framework from Nous Research, covering everything from onboarding to advanced development.'
        },
        href: 'https://github.com/alchaincyf/hermes-agent-orange-book'
      },
      {
        repo: 'KKKKhazix/khazix-skills',
        stars: '1650',
        summary: {
          zh: '围绕数字角色与具体场景开源的一组 AI 技能集合，展示了如何把能力设计成可复用模块。',
          en: 'An open set of AI skills built around digital personas and concrete scenarios, showing how capabilities can be packaged as reusable modules.'
        },
        href: 'https://github.com/KKKKhazix/khazix-skills'
      },
      {
        repo: 'adamlyttleapps/claude-skill-app-onboarding-questionnaire',
        stars: '753',
        summary: {
          zh: '一个 Claude Code 技能，用于生成高转化的问卷式产品引导流程，体现了 AI 在增长策略中的落地价值。',
          en: 'A Claude Code skill for building high-conversion questionnaire-based onboarding flows, showing a concrete AI use case in product growth.'
        },
        href: 'https://github.com/adamlyttleapps/claude-skill-app-onboarding-questionnaire'
      },
      {
        repo: 'tmstack/awesome-persona-skills',
        stars: '682',
        summary: {
          zh: '另一个高质量的人格技能列表，覆盖同事、老板、前任等角色，再次证明个性化 Agent 的需求正在扩大。',
          en: 'Another strong collection of persona skills that spans roles like coworkers, bosses, and ex-partners, reinforcing demand for personalized agents.'
        },
        href: 'https://github.com/tmstack/awesome-persona-skills'
      },
      {
        repo: 'joeynyc/hermes-hudui',
        stars: '607',
        summary: {
          zh: '为 Hermes 提供 Web UI 监控界面，有助于理解、调试和观察复杂 Agent 的长期行为。',
          en: 'A Web UI monitor for Hermes that helps teams inspect, debug, and understand long-running agent behavior.'
        },
        href: 'https://github.com/joeynyc/hermes-hudui'
      },
      {
        repo: 'alchaincyf/x-mentor-skill',
        stars: '604',
        summary: {
          zh: '蒸馏顶级 X 创作者方法论的导师型技能，体现了 AI 在内容创作和策略辅导上的新机会。',
          en: 'A mentor-style skill distilled from top X creators, illustrating new opportunities for AI in content strategy and coaching.'
        },
        href: 'https://github.com/alchaincyf/x-mentor-skill'
      }
    ]
  },
  {
    icon: '🧠',
    title: {
      zh: '大模型与多模态技术',
      en: 'LLM & Multimodal'
    },
    items: [
      {
        repo: 'mattmireles/gemma-tuner-multimodal',
        stars: '1202',
        summary: {
          zh: '支持在 Apple Silicon 上使用 PyTorch 和 MPS 对 Gemma 系列进行音频、图像与文本的多模态微调，显示出本地高效 AI 开发的趋势。',
          en: 'Supports multimodal fine-tuning of Gemma models on Apple Silicon with PyTorch and MPS, signaling the rise of efficient local AI development.'
        },
        href: 'https://github.com/mattmireles/gemma-tuner-multimodal'
      }
    ]
  },
  {
    icon: '🛠️',
    title: {
      zh: 'AI 驱动的开发者工具',
      en: 'AI-Powered Dev Tools'
    },
    items: [
      {
        repo: 'yizhiyanhua-ai/fireworks-tech-graph',
        stars: '1238',
        summary: {
          zh: '一个 Claude Code 技能，能够生成生产级 SVG 和 PNG 技术图表，显著提升技术文档与方案表达效率。',
          en: 'A Claude Code skill that generates production-quality SVG and PNG technical diagrams, greatly improving technical communication.'
        },
        href: 'https://github.com/yizhiyanhua-ai/fireworks-tech-graph'
      },
      {
        repo: 'phuryn/claude-usage',
        stars: '864',
        summary: {
          zh: '本地仪表板，用于追踪 Claude Code 的令牌消耗、成本与会话历史，适合团队做 AI 成本治理。',
          en: 'A local dashboard for tracking Claude Code usage, cost, and session history, useful for AI cost governance.'
        },
        href: 'https://github.com/phuryn/claude-usage'
      },
      {
        repo: 'QLHazyCoder/codex-oauth-automation-extension',
        stars: '766',
        summary: {
          zh: '面向 OpenAI 生态工作流的浏览器自动化扩展，展示了围绕 AI 产品的辅助工具仍有很强需求。',
          en: 'A browser automation extension for OpenAI ecosystem workflows, showing the continuing demand for operational tooling around AI products.'
        },
        href: 'https://github.com/QLHazyCoder/codex-oauth-automation-extension'
      },
      {
        repo: 'nashsu/llm_wiki',
        stars: '763',
        summary: {
          zh: '一款跨平台桌面应用，可把文档组织成互联知识库，为 RAG 和持续知识维护提供了新的思路。',
          en: 'A cross-platform desktop app that turns documents into an interconnected knowledge base, offering a practical angle on RAG and persistent knowledge maintenance.'
        },
        href: 'https://github.com/nashsu/llm_wiki'
      }
    ]
  },
  {
    icon: '🚀',
    title: {
      zh: '其他值得关注项目',
      en: 'Other Noteworthy Projects'
    },
    items: [
      {
        repo: 'farzaa/clicky',
        stars: '3842',
        summary: {
          zh: '关注度极高，可能代表了某种创新的 Web 产品形态、游戏机制或前端实验，值得继续观察。',
          en: 'A breakout project with strong attention, likely representing a fresh web product pattern, game mechanic, or frontend experiment worth watching.'
        },
        href: 'https://github.com/farzaa/clicky'
      },
      {
        repo: 'wxtsky/CodeIsland',
        stars: '853',
        summary: {
          zh: '趋势项目，可能是新的代码学习平台、开发环境或技术沙箱，具备潜在教育和社区价值。',
          en: 'A trending project that may point to a new code-learning platform, developer environment, or technical sandbox with community potential.'
        },
        href: 'https://github.com/wxtsky/CodeIsland'
      },
      {
        repo: 'xtclovver/RKNHardering',
        stars: '693',
        summary: {
          zh: '可能与系统加固、软件强化或底层基础设施相关，值得在安全与工程交叉领域继续跟踪。',
          en: 'Likely related to system hardening, software reinforcement, or low-level infrastructure, making it worth tracking at the intersection of security and engineering.'
        },
        href: 'https://github.com/xtclovver/RKNHardering'
      }
    ]
  }
];
---

<Layout titleZh='开源热点周报 | 谢灵江' titleEn='Open Source Weekly | James Xie' descriptionZh='每周开源热点追踪，聚焦 AI Agent、开发工具、多模态与高潜力基础设施项目。' descriptionEn='A weekly open-source digest focused on AI agents, developer tools, multimodal advances, and promising infrastructure projects.' ogImage='/og-opensource.svg'>
  <section class='bg-dark px-4 py-20 min-h-screen border-t border-emerald-400/10'>
    <div class='max-w-6xl mx-auto'>
      <h1 class='text-4xl font-bold text-center mb-4 text-white'>
        <span class='lang-zh'>开源<span class='text-emerald-400'>热点周报</span></span>
        <span class='lang-en hidden'>Open Source <span class='text-emerald-400'>Weekly</span></span>
      </h1>
      <p class='text-center text-gray-400 mb-12'>
        <span class='lang-zh'>由 GitHub Scout Agent 自动追踪的最具潜力的开源基础设施项目</span>
        <span class='lang-en hidden'>Promising open-source infrastructure projects tracked automatically by the GitHub Scout Agent</span>
      </p>
      <p class='text-center text-gray-600 text-sm mb-4'>
        <span class='lang-zh'>最后更新：2026年4月12日</span>
        <span class='lang-en hidden'>Last updated: Apr 12, 2026</span>
      </p>
      <div class='h-1 w-16 bg-emerald-400 mx-auto mb-16'></div>

      <div class='mb-16 p-8 bg-emerald-400/5 border border-emerald-400/30 rounded-lg'>
        <h2 class='text-2xl font-bold text-emerald-400 mb-4 flex items-center'>
          <span class='mr-3'>🧠</span>
          <span class='lang-zh'>首要信号</span>
          <span class='lang-en hidden'>Executive Summary</span>
        </h2>
        <div class='text-gray-300 space-y-4 leading-relaxed'>
          <p>
            <span class='lang-zh'>本周 GitHub 趋势清晰表明，<strong class='text-white'>AI Agent 生态系统正在经历爆发式增长与专业化分层</strong>。技能、人格与任务编排，正在成为构建高效 Agent 的核心变量。与此同时，多模态微调、成本治理与知识库构建等配套能力，也在快速走向实用化。</span>
            <span class='lang-en hidden'>This week on GitHub, one signal stands out clearly: <strong class='text-white'>the AI agent ecosystem is moving through explosive growth and rapid specialization</strong>. Skills, personas, and task orchestration are becoming core building blocks for effective agents. At the same time, multimodal fine-tuning, cost governance, and knowledge-base tooling are becoming increasingly practical.</span>
          </p>
          <div class='mt-6 p-5 bg-dark/80 border-l-4 border-emerald-400 shadow-inner'>
            <h3 class='text-white font-bold mb-3'>
              <span class='lang-zh'>💡 对独立开发者的建议：</span>
              <span class='lang-en hidden'>💡 Advice for indie builders:</span>
            </h3>
            <ul class='list-none text-gray-400 space-y-3'>
              {recommendations.map((item, index) => (
                <li>
                  <span class='text-emerald-400 mr-2'>{index + 1}.</span>
                  <strong>
                    <span class='lang-zh'>{item.zh}</span>
                    <span class='lang-en hidden'>{item.en}</span>
                  </strong>
                  <span class='lang-zh'>：{item.detailZh}</span>
                  <span class='lang-en hidden'>: {item.detailEn}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      {sections.map((section) => (
        <div class='mb-16'>
          <h2 class='text-2xl font-bold text-emerald-400 mb-8 flex items-center'>
            <span class='mr-3'>{section.icon}</span>
            <span class='lang-zh'>{section.title.zh}</span>
            <span class='lang-en hidden'>{section.title.en}</span>
          </h2>
          <div class='space-y-6'>
            {section.items.map((item) => (
              <article class='group p-6 border-l-2 border-emerald-400/30 hover:border-emerald-400 transition-colors hover:bg-dark/50'>
                <div class='flex justify-between items-start mb-3'>
                  <h3 class='text-lg font-bold text-white group-hover:text-emerald-400 transition-colors'>
                    {item.repo}
                  </h3>
                  <span class='text-sm text-gray-500 whitespace-nowrap ml-4'>⭐ {item.stars}</span>
                </div>
                <p class='text-gray-400 mb-3'>
                  <span class='lang-zh'>{item.summary.zh}</span>
                  <span class='lang-en hidden'>{item.summary.en}</span>
                </p>
                <div class='flex flex-wrap gap-4'>
                  <a href={item.href} target='_blank' rel='noopener' class='text-emerald-400 text-sm hover:text-white transition-colors'>GitHub →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}

      <div class='text-center mt-12'>
        <a href='/' class='inline-block px-8 py-3 border-2 border-emerald-400 text-emerald-400 hover:bg-emerald-400 hover:text-dark transition-all font-semibold'>
          <span class='lang-zh'>返回首页</span>
          <span class='lang-en hidden'>Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
