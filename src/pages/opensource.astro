---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const recommendations = [
  {
    zh: '关注 Agent Skills 生态位',
    en: 'Watch the Agent Skills niche',
    detailZh: '多个项目采用 "Skill" 命名和 MCP 架构，预示着 AI 能力分发市场正在形成。',
    detailEn: 'Multiple projects using "Skill" naming and MCP architecture signal an emerging AI capability market.'
  },
  {
    zh: '自愈合自动化是新方向',
    en: 'Self-healing automation is the new frontier',
    detailZh: '像 browser-harness 这样的自愈合框架解决了 AI 自动化中最脆弱的环节。',
    detailEn: 'Self-healing frameworks like browser-harness solve the most fragile parts of AI automation.'
  },
  {
    zh: '闭源模型的开源重构',
    en: 'Open source reconstruction of closed models',
    detailZh: '社区对 Claude Mythos 等尖端模型的逆向工程热情极高，值得技术型开发者跟进。',
    detailEn: 'Community passion for reverse-engineering models like Claude Mythos is high—worth following for technical builders.'
  },
  {
    zh: '产品即情报的订阅模式',
    en: 'Product-as-Intelligence subscription model',
    detailZh: 'BuilderPulse 证明了为开发者提供 AI 驱动的每日情报本身就是一个可行的产品形态。',
    detailEn: 'BuilderPulse shows that providing AI-driven daily intelligence for developers is a viable product form.'
  }
];

const sections = [
  {
    icon: '🤖',
    title: {
      zh: 'AI 智能体与技能生态',
      en: 'AI Agents & Skill Ecosystem'
    },
    items: [
      {
        repo: 'browser-use/browser-harness',
        stars: '2747',
        summary: {
          zh: '自愈合浏览器框架让 LLM 能够可靠地完成网页任务，解决了 AI 自动化中最脆弱的 UI 变动问题。',
          en: 'A self-healing browser framework allowing LLMs to reliably complete web tasks, solving the most fragile UI change issues.'
        },
        href: 'https://github.com/browser-use/browser-harness'
      },
      {
        repo: 'lewislulu/html-ppt-skill',
        stars: '1533',
        summary: {
          zh: '将 HTML 演示文稿制作封装为标准化的 Agent Skill，展示了“技能化”作为 AI 能力分发的新范式。',
          en: 'Encapsulating HTML PPT production as an Agent Skill, showcasing "skillization" as a new paradigm for AI capability distribution.'
        },
        href: 'https://github.com/lewislulu/html-ppt-skill'
      },
      {
        repo: 'Manavarya09/design-extract',
        stars: '1106',
        summary: {
          zh: '一键提取网站设计系统并支持多平台输出，适配 MCP 架构，成为 Claude Code/Cursor 的即插即用能力。',
          en: 'Extract website design systems with one click, supporting multi-platform output and MCP architecture for plug-and-play use.'
        },
        href: 'https://github.com/Manavarya09/design-extract'
      },
      {
        repo: 'cathrynlavery/diagram-design',
        stars: '773',
        summary: {
          zh: '为 Claude Code 提供 13 种高质量图表类型，专注专业级可视化表达。',
          en: 'Provides 13 high-quality diagram types for Claude Code, focusing on professional-grade technical visualization.'
        },
        href: 'https://github.com/cathrynlavery/diagram-design'
      }
    ]
  },
  {
    icon: '🏗️',
    title: {
      zh: 'AI 基础架构与模型',
      en: 'AI Infrastructure & Models'
    },
    items: [
      {
        repo: 'Robbyant/lingbot-map',
        stars: '2802',
        summary: {
          zh: '用于从流式数据重建场景的前馈 3D 基础模型，代表了多模态 AI 向真实世界理解迈进。',
          en: 'A feed-forward 3D foundation model for scene reconstruction from streaming data, moving multimodal AI toward real-world understanding.'
        },
        href: 'https://github.com/Robbyant/lingbot-map'
      },
      {
        repo: 'kyegomez/OpenMythos',
        stars: '2222',
        summary: {
          zh: '基于公开文献重构 Claude Mythos 架构，体现了社区对闭源模型“逆向工程”的热情。',
          en: 'Reconstructing Claude Mythos architecture from first principles, reflecting community passion for reverse-engineering.'
        },
        href: 'https://github.com/kyegomez/OpenMythos'
      },
      {
        repo: 'WeaveMindAI/weft',
        stars: '893',
        summary: {
          zh: '专为 AI 系统设计的新编程语言，标志着 AI 原生计算范式的深度探索。',
          en: 'A new programming language designed specifically for AI systems, marking a deep exploration of AI-native computing.'
        },
        href: 'https://github.com/WeaveMindAI/weft'
      }
    ]
  },
  {
    icon: '🛠️',
    title: {
      zh: '开发者工具',
      en: 'Developer Tools'
    },
    items: [
      {
        repo: 'vercel-labs/wterm',
        stars: '2137',
        summary: {
          zh: 'Vercel 推出的高性能 Web 终端模拟器，为云端开发环境和协作工具提供基础组件。',
          en: 'High-performance web terminal emulator by Vercel, providing core components for cloud development and collaboration.'
        },
        href: 'https://github.com/vercel-labs/wterm'
      }
    ]
  },
  {
    icon: '📊',
    title: {
      zh: '数据与情报',
      en: 'Data & Intelligence'
    },
    items: [
      {
        repo: 'BuilderPulse/BuilderPulse',
        stars: '991',
        summary: {
          zh: '为独立开发者提供每日 AI 驱动情报服务，“产品即情报”的订阅模式实践。',
          en: 'Daily AI-driven intelligence for independent developers, a practice of the "Product-as-Intelligence" subscription model.'
        },
        href: 'https://github.com/BuilderPulse/BuilderPulse'
      },
      {
        repo: 'wbh604/UZI-Skill',
        stars: '906',
        summary: {
          zh: '整合投资名家方法论与量化规则的 AI 技能，展示了垂直领域知识库的智能化价值。',
          en: 'An AI skill integrating expert methodologies and quantitative rules, showcasing the value of vertical domain knowledge bases.'
        },
        href: 'https://github.com/wbh604/UZI-Skill'
      }
    ]
  }
];
---

<Layout titleZh="开源热点周报 | 谢灵江" titleEn="Open Source Weekly | James Xie" descriptionZh="开源热点周报，汇总 GitHub 最具潜力的开源项目与 AI 趋势。" descriptionEn="Open Source Weekly, a digest of the most promising GitHub projects and AI trends." ogImage="/og-opensource.svg">
  <section class="bg-dark px-4 py-20 min-h-screen border-t border-emerald-400/10">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4 text-white">
        <span class="lang-zh">开源<span class="text-emerald-400">热点周报</span></span>
        <span class="lang-en hidden">Open Source <span class="text-emerald-400">Weekly</span></span>
      </h1>
      <p class="text-center text-gray-400 mb-12">
        <span class="lang-zh">由 GitHub Scout Agent 自动追踪的最具潜力的开源基础设施项目</span>
        <span class="lang-en hidden">Promising open-source infrastructure projects tracked automatically by the GitHub Scout Agent</span>
      </p>
      <p class="text-center text-gray-600 text-sm mb-4">
        <span class="lang-zh">最后更新：2026年4月20日</span>
        <span class="lang-en hidden">Last updated: April 20, 2026</span>
      </p>
      <div class="h-1 w-16 bg-emerald-400 mx-auto mb-16"></div>

      <div class="mb-16 p-8 bg-emerald-400/5 border border-emerald-400/30 rounded-lg">
        <h2 class="text-2xl font-bold text-emerald-400 mb-4 flex items-center">
          <span class="mr-3">🧠</span>
          <span class="lang-zh">首要信号</span>
          <span class="lang-en hidden">Executive Summary</span>
        </h2>
        <div class="text-gray-300 space-y-4 leading-relaxed">
          <p>
            <span class="lang-zh">今日实时抓取的 Scout 简报显示，<strong class="text-white">“Agent 技能化”与“自动化基础设施”</strong>正成为核心热点。开发者正在将 AI 能力封装为可复用的技能，同时浏览器自动化、设计系统提取等工具化方向备受关注。</span>
            <span class="lang-en hidden">Real-time signals from today's Scout briefing highlight <strong class="text-white">"Agent Skillization" and "Automation Infrastructure"</strong> as core hotspots. Developers are encapsulating AI capabilities into reusable skills, with strong focus on browser automation and design system extraction.</span>
          </p>
          <div class="mt-6 p-5 bg-dark/80 border-l-4 border-emerald-400 shadow-inner">
            <h3 class="text-white font-bold mb-3">
              <span class="lang-zh">💡 对独立开发者的建议：</span>
              <span class="lang-en hidden">💡 Advice for indie builders:</span>
            </h3>
            <ul class="list-none text-gray-400 space-y-3">
              {recommendations.map((item, index) => (
                <li>
                  <span class="text-emerald-400 mr-2">{index + 1}.</span>
                  <strong>
                    <span class="lang-zh">{item.zh}</span>
                    <span class="lang-en hidden">{item.en}</span>
                  </strong>
                  <span class="lang-zh">：{item.detailZh}</span>
                  <span class="lang-en hidden">: {item.detailEn}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      {sections.map((section) => (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-emerald-400 mb-8 flex items-center">
            <span class="mr-3">{section.icon}</span>
            <span class="lang-zh">{section.title.zh}</span>
            <span class="lang-en hidden">{section.title.en}</span>
          </h2>
          <div class="space-y-6">
            {section.items.map((item) => (
              <article class="group p-6 border-l-2 border-emerald-400/30 hover:border-emerald-400 transition-colors hover:bg-dark/50">
                <div class="flex justify-between items-start mb-3">
                  <h3 class="text-lg font-bold text-white group-hover:text-emerald-400 transition-colors">
                    {item.repo}
                  </h3>
                  <span class="text-sm text-gray-500 whitespace-nowrap ml-4">⭐ {item.stars}</span>
                </div>
                <p class="text-gray-400 mb-3">
                  <span class="lang-zh">{item.summary.zh}</span>
                  <span class="lang-en hidden">{item.summary.en}</span>
                </p>
                <div class="flex flex-wrap gap-4">
                  <a href={item.href} target="_blank" rel="noopener" class="text-emerald-400 text-sm hover:text-white transition-colors">GitHub →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}

      <div class="text-center mt-12">
        <a href="/" class="inline-block px-8 py-3 border-2 border-emerald-400 text-emerald-400 hover:bg-emerald-400 hover:text-dark transition-all font-semibold">
          <span class="lang-zh">返回首页</span>
          <span class="lang-en hidden">Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
