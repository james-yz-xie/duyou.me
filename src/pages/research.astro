---

<Layout titleZh="AI 研究成果 | 谢灵江" titleEn="AI Research | James Xie" descriptionZh="谢灵江的 AI 研究成果页，收录产业分析、Agent 架构、本地部署与实战方法论。" descriptionEn="James Xie's AI research archive covering industry analysis, agent architecture, local deployment, and practical execution insights." ogImage="/og-research.svg">
  <section class="bg-dark px-4 py-20 min-h-screen">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4 text-white">
        <span class="lang-zh">AI 研究<span class="text-gold">成果</span></span>
        <span class="lang-en hidden">AI <span class="text-gold">Research</span></span>
      </h1>
      <p class="text-center text-gray-400 mb-12">
        <span class="lang-zh">公众号「谢先生的AI深析札记」已发布文章</span>
        <span class="lang-en hidden">Published articles from the WeChat newsletter "Mr. Xie’s AI Deep Dive Notes"</span>
      </p>
      <p class="text-center text-gray-600 text-sm mb-4">
        <span class="lang-zh">最后更新：2026年5月10日</span>
        <span class="lang-en hidden">Last updated: May 10, 2026</span>
      </p>
      <div class="h-1 w-16 bg-gold mx-auto mb-4"></div>
      
      <p class="text-center mb-12">
        <a href="weixin://contacts/profile/gh_f297261425ba" class="text-gold hover:text-white transition-colors">
          <span class="lang-zh">关注公众号阅读全文 →</span>
          <span class="lang-en hidden">Follow on WeChat for the full articles →</span>
        </a>
      </p>

      <div class="space-y-8">
        {articles.map((article) => (
          <article class="group p-6 border-l-2 border-gold/30 hover:border-gold transition-colors hover:bg-dark/50">
            <div class="flex justify-between items-start mb-3">
              <h3 class="text-lg font-bold text-white group-hover:text-gold transition-colors">
                <span class="lang-zh">{article.title.zh}</span>
                <span class="lang-en hidden">{article.title.en}</span>
              </h3>
              <span class="text-sm text-gray-500 whitespace-nowrap ml-4">
                <span class="lang-zh">{article.category.zh}</span>
                <span class="lang-en hidden">{article.category.en}</span>
              </span>
            </div>
            <p class="text-gray-400 mb-3">
              <span class="lang-zh">{article.excerpt.zh}</span>
              <span class="lang-en hidden">{article.excerpt.en}</span>
            </p>
            <span class="text-gray-500 text-sm">
              <span class="lang-zh">{article.status.zh}</span>
              <span class="lang-en hidden">{article.status.en}</span>
            </span>
          </article>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/" class="inline-block px-8 py-3 border-2 border-gold text-gold hover:bg-gold hover:text-dark transition-all font-semibold">
          <span class="lang-zh">返回首页</span>
          <span class="lang-en hidden">Back to Home</span>
        </a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
