---
---

<section id="studio" class="bg-dark px-4 py-20 border-t border-gold/10">
  <div class="max-w-4xl mx-auto">
    <!-- 中文内容 -->
    <div class="lang-zh">
      <h2 class="text-4xl font-bold text-center mb-4 text-white">
        工作<span class="text-gold">台</span>
      </h2>
      <div class="h-1 w-16 bg-gold mx-auto mb-12"></div>

      <!-- 图片占位符 -->
      <div class="relative group rounded-lg overflow-hidden border-2 border-gold/30 hover:border-gold transition-all bg-gradient-to-br from-dark to-dark">
        <div class="absolute inset-0 bg-gradient-to-br from-gold/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="relative aspect-video flex items-center justify-center bg-dark/50">
          <!-- 占位符内容 -->
          <div class="text-center">
            <div class="mb-6">
              <svg class="w-16 h-16 mx-auto text-gold/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <p class="text-gray-400 text-lg font-semibold mb-2">MacBook Pro M5 Max · 64GB</p>
            <p class="text-gray-500 text-sm">工作台照片敬请期待</p>
          </div>
        </div>

        <!-- 涟漪效果背景 -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-5 transition-opacity">
          <div class="absolute inset-0 bg-gold animate-pulse"></div>
        </div>
      </div>

      <!-- 配置说明 -->
      <div class="mt-12 grid md:grid-cols-3 gap-6 text-center">
        <div>
          <p class="text-gold text-sm font-bold mb-2">处理器</p>
          <p class="text-gray-300">Apple M5 Max</p>
        </div>
        <div>
          <p class="text-gold text-sm font-bold mb-2">内存</p>
          <p class="text-gray-300">64GB 统一内存</p>
        </div>
        <div>
          <p class="text-gold text-sm font-bold mb-2">用途</p>
          <p class="text-gray-300">本地 AI 研究</p>
        </div>
      </div>
    </div>
    
    <!-- 英文内容 -->
    <div class="lang-en hidden">
      <h2 class="text-4xl font-bold text-center mb-4 text-white">
        Work<span class="text-gold">station</span>
      </h2>
      <div class="h-1 w-16 bg-gold mx-auto mb-12"></div>

      <!-- 图片占位符 -->
      <div class="relative group rounded-lg overflow-hidden border-2 border-gold/30 hover:border-gold transition-all bg-gradient-to-br from-dark to-dark">
        <div class="absolute inset-0 bg-gradient-to-br from-gold/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="relative aspect-video flex items-center justify-center bg-dark/50">
          <!-- 占位符内容 -->
          <div class="text-center">
            <div class="mb-6">
              <svg class="w-16 h-16 mx-auto text-gold/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <p class="text-gray-400 text-lg font-semibold mb-2">MacBook Pro M5 Max · 64GB</p>
            <p class="text-gray-500 text-sm">Workstation photo coming soon</p>
          </div>
        </div>

        <!-- 涟漪效果背景 -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-5 transition-opacity">
          <div class="absolute inset-0 bg-gold animate-pulse"></div>
        </div>
      </div>

      <!-- 配置说明 -->
      <div class="mt-12 grid md:grid-cols-3 gap-6 text-center">
        <div>
          <p class="text-gold text-sm font-bold mb-2">Processor</p>
          <p class="text-gray-300">Apple M5 Max</p>
        </div>
        <div>
          <p class="text-gold text-sm font-bold mb-2">Memory</p>
          <p class="text-gray-300">64GB Unified Memory</p>
        </div>
        <div>
          <p class="text-gold text-sm font-bold mb-2">Purpose</p>
          <p class="text-gray-300">Local AI Research</p>
        </div>
      </div>
    </div>
  </div>
</section>
