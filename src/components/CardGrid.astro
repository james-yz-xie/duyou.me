---
---

<section class="bg-dark px-4 py-20">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-4xl font-bold text-center mb-4 text-white">
      核心<span class="text-gold">成果</span>
    </h2>
    <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- AI 研究成果卡片 -->
      <div class="group relative rounded-lg border-2 border-gold/30 hover:border-gold transition-all p-8 bg-gradient-to-br from-dark to-dark/80">
        <div class="absolute inset-0 rounded-lg bg-gradient-to-br from-gold/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="relative z-10">
          <h3 class="text-2xl font-bold text-gold mb-2">AI 研究成果</h3>
          <div class="h-1 w-8 bg-gold mb-6"></div>
          
          <p class="text-gray-300 mb-6">
            本地模型性能测试与优化、多模态能力评估、推理速度对标
          </p>

          <div class="space-y-3 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <span class="text-gold">→</span>
              <span><span class="text-white font-semibold">Llama 2 70B</span> 本地部署跑分</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-gold">→</span>
              <span><span class="text-white font-semibold">视觉理解</span>多模态能力测试</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-gold">→</span>
              <span><span class="text-white font-semibold">推理链优化</span>财务审计场景</span>
            </div>
          </div>

          <div class="mt-8 pt-6 border-t border-gold/20">
            <button class="text-gold hover:text-white transition-colors font-semibold">
              查看详细报告 →
            </button>
          </div>
        </div>
      </div>

      <!-- 财务 AI 深度文章卡片 -->
      <div class="group relative rounded-lg border-2 border-gold/30 hover:border-gold transition-all p-8 bg-gradient-to-br from-dark to-dark/80">
        <div class="absolute inset-0 rounded-lg bg-gradient-to-br from-gold/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        
        <div class="relative z-10">
          <h3 class="text-2xl font-bold text-gold mb-2">财务 AI 深度文章</h3>
          <div class="h-1 w-8 bg-gold mb-6"></div>
          
          <p class="text-gray-300 mb-6">
            AI 在财务审计中的应用、模型可解释性、合规风险分析
          </p>

          <div class="space-y-3 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <span class="text-gold">→</span>
              <span><span class="text-white font-semibold">审计自动化</span>AI 应用方案</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-gold">→</span>
              <span><span class="text-white font-semibold">可解释性</span>黑箱模型风险</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-gold">→</span>
              <span><span class="text-white font-semibold">合规框架</span>金融 AI 监管</span>
            </div>
          </div>

          <div class="mt-8 pt-6 border-t border-gold/20">
            <button class="text-gold hover:text-white transition-colors font-semibold">
              阅读全文 →
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
