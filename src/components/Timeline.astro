---
---

<section id="timeline" class="bg-dark px-4 py-20">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-4xl font-bold text-center mb-4 text-white">
      项目<span class="text-gold">里程碑</span>
    </h2>
    <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

    <div class="relative space-y-8">
      <!-- 时间线线条 -->
      <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-gold to-transparent"></div>

      <!-- 时间线项 -->
      <div class="relative mb-8">
        <div class="grid grid-cols-2 gap-4 items-center mb-4">
          <div class="text-right pr-8">
            <h3 class="text-xl font-bold text-white">硬件升级</h3>
            <p class="text-gray-400">2026年3月</p>
          </div>
          <div class="text-left pl-8">
            <p class="text-gray-300">购置 MacBook Pro M5 Max 64GB，搭建本地 AI 研究工作台</p>
          </div>
        </div>
        <div class="w-6 h-6 bg-gold rounded-full border-4 border-dark absolute left-1/2 transform -translate-x-1/2 -mt-8"></div>
      </div>

      <div class="relative mb-8">
        <div class="grid grid-cols-2 gap-4 items-center mb-4">
          <div class="text-right pr-8">
            <p class="text-gray-300">duyou.me 首页发布，展示项目与研究成果</p>
          </div>
          <div class="text-left pl-8">
            <h3 class="text-xl font-bold text-white">域名上线</h3>
            <p class="text-gray-400">2026年4月</p>
          </div>
        </div>
        <div class="w-6 h-6 bg-gold rounded-full border-4 border-dark absolute left-1/2 transform -translate-x-1/2 -mt-8"></div>
      </div>

      <div class="relative mb-8">
        <div class="grid grid-cols-2 gap-4 items-center mb-4">
          <div class="text-right pr-8">
            <h3 class="text-xl font-bold text-white">AI 研究深化</h3>
            <p class="text-gray-400">进行中</p>
          </div>
          <div class="text-left pl-8">
            <p class="text-gray-300">本地模型优化、多模态能力探索、财务 AI 应用研究</p>
          </div>
        </div>
        <div class="w-6 h-6 bg-gold rounded-full border-4 border-dark absolute left-1/2 transform -translate-x-1/2 -mt-8"></div>
      </div>
    </div>
  </div>
</section>
