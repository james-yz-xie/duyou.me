<section id="timeline" class="bg-dark px-4 py-20">
  <div class="max-w-4xl mx-auto">
    <!-- 中文内容 -->
    <div class="lang-zh">
      <h2 class="text-4xl font-bold text-center mb-4 text-white">
        项目<span class="text-gold">里程碑</span>
      </h2>
      <div class="h-1 w-16 bg-gold mx-auto mb-16"></div>

      <div class="relative space-y-8">
        <!-- 时间线线条 -->
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-gold to-transparent"></div>

        <!-- 时间线项 1: 公众号 -->
        <div class="relative mb-8">
          <div class="grid grid-cols-2 gap-4 items-center mb-4">
            <div class="text-right pr-8">
              <h3 class="text-xl font-bold text-white">公众号上线</h3>
              <p class="text-gray-400">2026年1月</p>
            </div>
            <div class="text-left pl-8">
              <p class="text-gray-300">「谢先生的AI深析札记」创刊，专注 AI 技术深度解析与行业洞察</p>
