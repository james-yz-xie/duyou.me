              <p class="text-gray-400">2026年3月</p>
            </div>
            <div class="text-left pl-8">
              <p class="text-gray-300">购置 MacBook Pro M5 Max 64GB，搭建本地 AI 研究工作台</p>
            </div>
          </div>
          <div class="w-6 h-6 bg-gold rounded-full border-4 border-dark absolute left-1/2 transform -translate-x-1/2 -mt-8"></div>
        </div>

        <!-- 时间线项 4: 域名上线 -->
