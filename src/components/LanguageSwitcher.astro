---

<div class="language-switcher fixed top-8 right-3 z-40" style="top: env(safe-area-inset-top, 1rem);">
  <button id="language-toggle" class="px-2 py-1 bg-black/80 backdrop-blur-xl text-white/60 text-[10px] font-medium rounded-full border border-white/10 hover:text-white/90 hover:border-white/20 transition-all">
    中 / EN
  </button>
</div>

<script>
  // 语言切换功能
  const toggleBtn = document.getElementById('language-toggle');
  const langKey = 'preferredLanguage';
  
  function detectBrowserLanguage() {
    const browserLang = navigator.languages?.[0] || navigator.language || 'zh';
    return browserLang.toLowerCase().startsWith('zh') ? 'zh' : 'en';
  }

  // 初始化语言
  function initLanguage() {
    const savedLang = localStorage.getItem(langKey);
    const initialLang = savedLang || detectBrowserLanguage();
    document.documentElement.lang = initialLang;
    updateContent(initialLang);
  }
  
  // 切换语言
  toggleBtn.addEventListener('click', () => {
    const currentLang = document.documentElement.lang;
    const newLang = currentLang === 'zh' ? 'en' : 'zh';
    localStorage.setItem(langKey, newLang);
    document.documentElement.lang = newLang;
    updateContent(newLang);
  });
  
  // 更新内容
  function updateContent(lang) {
    // 更新语言切换按钮文本
    toggleBtn.textContent = lang === 'zh' ? '中 / EN' : 'EN / 中';
    
    // 触发自定义事件，通知 Layout 和其他组件更新
    document.dispatchEvent(new CustomEvent('languageChanged', { detail: { lang } }));
  }
  
  // 初始化
  initLanguage();
</script>