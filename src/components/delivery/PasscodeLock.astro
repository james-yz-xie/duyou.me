---
---

<div id="auth-overlay" class="fixed inset-0 z-[100] bg-dark flex items-center justify-center px-4 transition-opacity duration-700">
  <!-- Dynamic Background Particles (Optional Aesthetic) -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gold/5 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-gold/5 blur-[120px] rounded-full"></div>
  </div>

  <div class="relative z-10 max-w-md w-full text-center slide-up">
    <!-- Icon -->
    <div class="mb-8 inline-flex items-center justify-center w-20 h-20 rounded-full bg-gold/10 border border-gold/20">
      <svg class="w-10 h-10 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
      </svg>
    </div>

    <h2 class="text-3xl font-bold text-white mb-2">私密阅览</h2>
    <p class="text-gray-400 mb-10">请输入访问密码查看商业演示方案</p>

    <div class="space-y-6">
      <div class="relative group">
        <input 
          type="password" 
          id="passcode-input" 
          placeholder="Enter Passcode"
          class="w-full bg-white/5 border-2 border-white/10 rounded-sm py-4 px-6 text-white text-center text-xl tracking-[0.5em] focus:border-gold/50 focus:outline-none transition-all placeholder:text-gray-700 placeholder:tracking-normal group-hover:border-white/20"
        />
        <div id="error-msg" class="absolute -bottom-8 left-0 w-full text-rose-500 text-sm opacity-0 transition-opacity">
          密码错误，请核对后再试
        </div>
      </div>

      <button 
        id="unlock-btn"
        class="w-full py-4 bg-gold text-dark font-black tracking-widest uppercase hover:scale-[1.02] active:scale-[0.98] transition-all shadow-xl shadow-gold/10"
      >
        解锁方案
      </button>
    </div>

    <p class="mt-12 text-gray-600 text-xs uppercase tracking-[0.2em]">
      Restricted Access &copy; 2026 DuYou
    </p>
  </div>
</div>

<style>
  .slide-up {
    animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Prevent scroll while locked */
  :global(body.locked) {
    overflow: hidden;
  }

  /* Fade out content initially */
  :global(#main-content.locked) {
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  const AUTH_KEY = 'delivery_auth_token';
  const VALID_PASSCODE = 'james';

  const overlay = document.getElementById('auth-overlay');
  const input = document.getElementById('passcode-input') as HTMLInputElement;
  const btn = document.getElementById('unlock-btn');
  const errMsg = document.getElementById('error-msg');
  const mainContent = document.getElementById('main-content');
  const body = document.body;

  function checkAuth() {
    if (sessionStorage.getItem(AUTH_KEY) === 'true') {
      unlock(true);
    } else {
      body.classList.add('locked');
      mainContent?.classList.add('locked');
    }
  }

  function unlock(immediate = false) {
    sessionStorage.setItem(AUTH_KEY, 'true');
    
    if (immediate) {
      overlay?.style.setProperty('display', 'none');
      mainContent?.classList.remove('locked');
      mainContent?.style.setProperty('opacity', '1');
      body.classList.remove('locked');
    } else {
      overlay?.classList.add('opacity-0');
      setTimeout(() => {
        overlay?.style.setProperty('display', 'none');
        mainContent?.classList.remove('locked');
        mainContent?.style.setProperty('opacity', '1');
        mainContent?.style.setProperty('transition', 'opacity 1s ease-out');
        body.classList.remove('locked');
      }, 700);
    }
  }

  function handleUnlock() {
    if (input.value.toLowerCase() === VALID_PASSCODE) {
      unlock();
    } else {
      errMsg?.classList.remove('opacity-0');
      input.classList.add('border-rose-500/50');
      
      // Shake animation
      const container = input.parentElement;
      container?.classList.add('animate-shake');
      setTimeout(() => container?.classList.remove('animate-shake'), 500);
      
      setTimeout(() => {
        errMsg?.classList.add('opacity-0');
        input.classList.remove('border-rose-500/50');
      }, 3000);
    }
  }

  btn?.addEventListener('click', handleUnlock);
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') handleUnlock();
  });

  // Initialize
  checkAuth();
</script>

<style is:global>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-8px); }
    75% { transform: translateX(8px); }
  }
  .animate-shake {
    animation: shake 0.2s ease-in-out 2;
  }
</style>
