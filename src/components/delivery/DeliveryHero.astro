---
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/delivery_hero.png" 
      alt="Enterprise AI Connectivity" 
      class="w-full h-full object-cover opacity-60 scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/80 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-transparent to-dark/90"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 text-center">
    <div class="inline-block px-4 py-1 border border-gold/30 rounded-full bg-gold/5 backdrop-blur-sm mb-6 animate-fade-in">
      <span class="text-gold text-sm font-bold tracking-[0.2em] uppercase">Enterprise AI Solutions</span>
    </div>
    
    <h1 class="text-5xl md:text-7xl font-bold mb-6 text-white leading-tight">
      企业的 <span class="bg-gradient-to-r from-gold via-gold/80 to-gold bg-clip-text text-transparent italic">AI 技能递送者</span>
    </h1>
    
    <div class="max-w-3xl mx-auto">
      <p class="text-2xl md:text-3xl text-gray-200 font-medium mb-8 leading-relaxed">
        “AI 懂你的业务，却无法触碰你的系统？我们负责连接。”
      </p>
      
      <div class="h-1 w-24 bg-gold mx-auto mb-10"></div>
      
      <!-- Value Badges -->
      <div class="flex flex-wrap justify-center gap-4 mb-10">
        <div class="px-3 py-1 bg-white/5 border border-white/10 rounded text-[10px] text-gray-400 uppercase tracking-widest flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
          Zero Token Runtime
        </div>
        <div class="px-3 py-1 bg-white/5 border border-white/10 rounded text-[10px] text-gray-400 uppercase tracking-widest flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-gold rounded-full shadow-[0_0_8px_rgba(255,215,0,0.5)]"></span>
          Deterministic Connection
        </div>
        <div class="px-3 py-1 bg-white/5 border border-white/10 rounded text-[10px] text-gray-400 uppercase tracking-widest flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-blue-500 rounded-full shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
          Legacy Friendly
        </div>
      </div>

      <p class="text-lg md:text-xl text-gray-400 mb-12 max-w-2xl mx-auto leading-relaxed">
        打破“信息孤岛”，利用<b>自研核心连接适配技术</b>，将企业遗留系统与专业软件无缝接入 AGI 时代。
      </p>
    </div>

    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 md:gap-6">
      <a href="#services" class="w-full sm:w-auto px-10 py-3 bg-gold text-dark font-bold rounded-sm hover:scale-105 transition-all shadow-xl shadow-gold/10 text-center">
        服务方案
      </a>
      <a 
        href="#presentation-viewer" 
        class="w-full sm:w-auto px-10 py-3 bg-white/10 text-white font-bold rounded-sm hover:bg-white/20 transition-all flex items-center justify-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
        </svg>
        在线阅读
      </a>
      <a 
        href="#video-demo" 
        class="w-full sm:w-auto px-10 py-3 border-2 border-gold/30 text-gold font-bold rounded-sm hover:bg-gold/5 transition-all flex items-center justify-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        方案深度演示
      </a>
    </div>
  </div>

  <!-- Bottom Gradient Break -->
  <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-dark to-transparent"></div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }
</style>
