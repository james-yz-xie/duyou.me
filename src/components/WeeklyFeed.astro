              <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{item.date.zh}</span>
            </div>
            <p class="text-gray-400 mb-3">{item.summary.zh}</p>
            <div class="flex flex-wrap gap-4">
              {item.links.map((link) => (
                <a href={link.href} target="_blank" rel="noopener" class="text-gold text-sm hover:text-white transition-colors">{link.label}</a>
