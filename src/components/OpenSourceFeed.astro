---
const topProjects = [
  {
    icon: '🤖',
    title: {
      zh: 'browser-harness：LLM 驱动的自愈合浏览器框架',
      en: 'browser-harness: LLM-Driven Self-Healing Browser Framework'
    },
    stars: '⭐ 2.7k',
    summary: {
      zh: '自愈合浏览器框架让 LLM 能够可靠地完成网页任务，解决了 AI 自动化中最脆弱的环节。',
      en: 'A self-healing browser framework allowing LLMs to reliably complete web tasks, solving the most fragile part of AI automation.'
    },
    href: 'https://github.com/browser-use/browser-harness'
  },
  {
    icon: '🚀',
    title: {
      zh: 'html-ppt-skill：AI 能力分发的“技能化”新范式',
      en: 'html-ppt-skill: A New Paradigm of AI Capability Distribution'
    },
    stars: '⭐ 1.5k',
    summary: {
      zh: '将 HTML 演示文稿制作封装为标准化的 Agent Skill，预示着 AI 插件经济和 MCP 生态的崛起。',
      en: 'Encapsulating HTML presentation production as a standardized Agent Skill, signaling the rise of the AI plugin economy and MCP ecosystem.'
    },
    href: 'https://github.com/lewislulu/html-ppt-skill'
  },
  {
    icon: '💡',
    title: {
      zh: 'design-extract：面向 MCP 的网页设计系统提取器',
      en: 'design-extract: Web Design System Extractor for MCP'
    },
    stars: '⭐ 1.1k',
    summary: {
      zh: '一键提取任意网站设计系统，支持 MCP 服务器架构，使其成为 Claude Code/Cursor 的即插即用能力。',
      en: 'Extract any website design system with one click, supporting MCP server architecture for plug-and-play use in Claude Code/Cursor.'
    },
    href: 'https://github.com/Manavarya09/design-extract'
  }
];
---

<section id="opensource-feed" class="bg-dark px-4 py-20 border-t border-emerald-400/10">
  <div class="max-w-5xl mx-auto">
    <div class="lang-zh">
      <h2 class="text-4xl font-bold text-center mb-4 text-white">
        开源<span class="text-emerald-400">热点周报</span>
      </h2>
      <p class="text-center text-gray-400 mb-4">由 GitHub Scout Agent 自动追踪的最具潜力的开源项目</p>
      <p class="text-center text-gray-600 text-sm mb-4">最后更新：2026年4月20日</p>
      <div class="h-1 w-16 bg-emerald-400 mx-auto mb-10"></div>

      <div class="mb-12 p-6 bg-emerald-400/5 border border-emerald-400/25 rounded-lg text-gray-300 leading-relaxed">
        本期最强信号是<strong class="text-white">Agent 技能化与生态位爆发</strong>：开发者正将 AI 能力封装为可复用的“技能”，MCP 服务器架构正在重塑 AI 工具的即插即用体验。
      </div>

      <div class="space-y-6">
        {topProjects.map((project) => (
          <article class="group p-6 border-l-2 border-emerald-400/30 hover:border-emerald-400 transition-colors hover:bg-dark/50">
            <div class="flex justify-between items-start mb-3">
              <h3 class="text-lg font-bold text-white group-hover:text-emerald-400 transition-colors">
                {project.icon} {project.title.zh}
              </h3>
              <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{project.stars}</span>
            </div>
            <p class="text-gray-400 mb-3">{project.summary.zh}</p>
            <div class="flex gap-4">
              <a href={project.href} target="_blank" rel="noopener" class="text-emerald-400 text-sm hover:text-white transition-colors">GitHub →</a>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/opensource" class="inline-block px-8 py-3 border-2 border-emerald-400 text-emerald-400 hover:bg-emerald-400 hover:text-dark transition-all font-semibold">
          查看全部开源速递
        </a>
      </div>
    </div>
    
    <div class="lang-en hidden">
      <h2 class="text-4xl font-bold text-center mb-4 text-white">
        Open Source <span class="text-emerald-400">Hotspot Weekly</span>
      </h2>
      <p class="text-center text-gray-400 mb-4">Most promising open-source projects automatically tracked by GitHub Scout Agent</p>
      <p class="text-center text-gray-600 text-sm mb-4">Last updated: April 20, 2026</p>
      <div class="h-1 w-16 bg-emerald-400 mx-auto mb-10"></div>

      <div class="mb-12 p-6 bg-emerald-400/5 border border-emerald-400/25 rounded-lg text-gray-300 leading-relaxed">
        The clearest signal this cycle is <strong class="text-white">Agent Skillization and Ecosystem Boom</strong>: developers are encapsulating AI capabilities into reusable "Skills", and MCP server architecture is reshaping the plug-and-play experience for AI tools.
      </div>

      <div class="space-y-6">
        {topProjects.map((project) => (
          <article class="group p-6 border-l-2 border-emerald-400/30 hover:border-emerald-400 transition-colors hover:bg-dark/50">
            <div class="flex justify-between items-start mb-3">
              <h3 class="text-lg font-bold text-white group-hover:text-emerald-400 transition-colors">
                {project.icon} {project.title.en}
              </h3>
              <span class="text-sm text-gray-500 whitespace-nowrap ml-4">{project.stars}</span>
            </div>
            <p class="text-gray-400 mb-3">{project.summary.en}</p>
            <div class="flex gap-4">
              <a href={project.href} target="_blank" rel="noopener" class="text-emerald-400 text-sm hover:text-white transition-colors">GitHub →</a>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/opensource" class="inline-block px-8 py-3 border-2 border-emerald-400 text-emerald-400 hover:bg-emerald-400 hover:text-dark transition-all font-semibold">
          View All Open Source Updates
        </a>
      </div>
    </div>
  </div>
</section>
