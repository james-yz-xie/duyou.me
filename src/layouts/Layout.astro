---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = '督友 - AI独立开发者' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="一人公司展示墙 - eBay支付和AI专家，现为AI独立开发者，专注于督友项目" />
    <title>{title}</title>
  </head>
  <body class="bg-dark text-white">
    <slot />
  </body>
</html>
