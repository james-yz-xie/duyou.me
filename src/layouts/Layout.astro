---
import '../styles/global.css';
import Header from '../components/Header.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title?: string;
  titleZh?: string;
  titleEn?: string;
  description?: string;
  descriptionZh?: string;
  descriptionEn?: string;
  ogImage?: string;
  ogImageAltZh?: string;
  ogImageAltEn?: string;
}

const {
  title,
  titleZh = '督友 - AI独立开发者',
  titleEn = 'DuYou - AI Indie Developer',
  description,
  descriptionZh = '一人公司展示墙 - eBay支付和AI专家，现为AI独立开发者，专注于督友项目',
  descriptionEn = 'A solo builder showcase by James Xie, former eBay payments technical lead and AI indie developer focused on DuYou and enterprise AI delivery.',
  ogImage = '/og-home.svg',
  ogImageAltZh,
  ogImageAltEn
} = Astro.props;

const finalTitleZh = title || titleZh;
const finalTitleEn = titleEn || (title ? title.replace('James Xie | 独有·我', 'James Xie | Duyou·Me') : titleEn);
const finalDescriptionZh = description || descriptionZh;
const finalDescriptionEn = descriptionEn || (description ? description : descriptionEn);
const siteUrl = 'https://duyou.me';
const finalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const finalShareImage = new URL(ogImage, siteUrl).toString();
const finalShareImageAltZh = ogImageAltZh || `${finalTitleZh} 分享图`;
const finalShareImageAltEn = ogImageAltEn || `${finalTitleEn} social sharing image`;
const finalShareImageWidth = '1200';
const finalShareImageHeight = '630';
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#ffd700" />
    <meta name="description" data-zh={finalDescriptionZh} data-en={finalDescriptionEn} content={finalDescriptionZh} />
    <link rel="canonical" href={finalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="duyou.me" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:url" content={finalUrl} />
    <meta property="og:image" content={finalShareImage} />
    <meta property="og:image:width" content={finalShareImageWidth} />
    <meta property="og:image:height" content={finalShareImageHeight} />
    <meta property="og:image:alt" data-zh={finalShareImageAltZh} data-en={finalShareImageAltEn} content={finalShareImageAltZh} />
    <meta property="og:title" data-zh={finalTitleZh} data-en={finalTitleEn} content={finalTitleZh} />
    <meta property="og:description" data-zh={finalDescriptionZh} data-en={finalDescriptionEn} content={finalDescriptionZh} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@amirightnowok" />
    <meta name="twitter:creator" content="@amirightnowok" />
    <meta name="twitter:image" content={finalShareImage} />
    <meta name="twitter:image:alt" data-zh={finalShareImageAltZh} data-en={finalShareImageAltEn} content={finalShareImageAltZh} />
    <meta name="twitter:title" data-zh={finalTitleZh} data-en={finalTitleEn} content={finalTitleZh} />
    <meta name="twitter:description" data-zh={finalDescriptionZh} data-en={finalDescriptionEn} content={finalDescriptionZh} />
    <title data-zh={finalTitleZh} data-en={finalTitleEn}>{finalTitleZh}</title>
    <link rel="icon" type="image/png" sizes="192x192" href="/duyoufavicon.png" />
    <link rel="apple-touch-icon" href="/duyoufavicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="督友" />
    <meta name="format-detection" content="telephone=no" />
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "e1a62d18dcc347cfad025de5bfe2e2bc"}'></script>
  </head>
  <body class="bg-dark text-white pt-14">
    <Header />
    <LanguageSwitcher />
    <slot />

    <script is:inline>
      // 核心语言切换逻辑
      function updateLanguage() {
        const lang = document.documentElement.lang;

        document.querySelectorAll('.lang-zh').forEach(el => {
          // Skip navigation items to avoid conflict with responsive classes
          if (!el.closest('#floating-nav')) {
            el.classList.toggle('hidden', lang !== 'zh');
          }
        });
        document.querySelectorAll('.lang-en').forEach(el => {
          // Skip navigation items to avoid conflict with responsive classes
          if (!el.closest('#floating-nav')) {
            el.classList.toggle('hidden', lang !== 'en');
          }
        });

        const titleEl = document.querySelector('title');
        if (titleEl) {
          const zh = titleEl.getAttribute('data-zh');
          const en = titleEl.getAttribute('data-en');
          if (zh && en) {
            document.title = lang === 'zh' ? zh : en;
          }
        }

        const descriptionEl = document.querySelector('meta[name="description"]');
        if (descriptionEl) {
          const zh = descriptionEl.getAttribute('data-zh');
          const en = descriptionEl.getAttribute('data-en');
          if (zh && en) {
            descriptionEl.setAttribute('content', lang === 'zh' ? zh : en);
          }
        }

        const metaPairs = [
          'meta[property="og:title"]',
          'meta[property="og:description"]',
          'meta[property="og:image:alt"]',
          'meta[name="twitter:title"]',
          'meta[name="twitter:description"]',
          'meta[name="twitter:image:alt"]'
        ];

        metaPairs.forEach((selector) => {
          const el = document.querySelector(selector);
          if (!el) return;
          const zh = el.getAttribute('data-zh');
          const en = el.getAttribute('data-en');
          if (zh && en) {
            el.setAttribute('content', lang === 'zh' ? zh : en);
          }
        });
      }

      updateLanguage();
      document.addEventListener('languageChanged', updateLanguage);

    </script>
  </body>
</html>